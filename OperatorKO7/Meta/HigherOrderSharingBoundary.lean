import OperatorKO7.Meta.SharingBarrierLift

/-!
# Higher-Order Sharing Boundary

This module makes one higher-order obstruction theorem-visible: an
unqualified lift of the tree-based duplication barrier cannot ignore the
sharing policy. The shared-policy branch admits a simple orienting counter, so
the no-sharing/tree hypothesis is load-bearing.
-/

namespace OperatorKO7.HigherOrderSharingBoundary

open OperatorKO7.SharingBarrierLift

/-- Minimal policy carrier for the higher-order sharing boundary. -/
inductive SharingPolicy
  | tree
  | shared
  deriving DecidableEq, Repr

/-- Minimal higher-order carrier used only to expose the sharing boundary. -/
inductive HOTerm : Type
  | base : HOTerm
  | succ : HOTerm → HOTerm
  | app : HOTerm → HOTerm → HOTerm
  | recur : HOTerm → HOTerm → HOTerm → HOTerm
  deriving DecidableEq, Repr

open HOTerm

/-- Closed fragment generated by the first-order recursor shape inside the
minimal higher-order carrier. -/
inductive HOClosedFragment : HOTerm → Prop
  | base : HOClosedFragment base
  | succ {t : HOTerm} : HOClosedFragment t → HOClosedFragment (succ t)
  | app {f a : HOTerm} : HOClosedFragment f → HOClosedFragment a → HOClosedFragment (app f a)
  | recur {b s n : HOTerm} :
      HOClosedFragment b → HOClosedFragment s → HOClosedFragment n →
      HOClosedFragment (recur b s n)

/-- Embedding of the existing sharing-aware first-order surrogate into the
minimal higher-order carrier. -/
@[simp] def embedSharedTerm : SharedTerm → HOTerm
  | .base => base
  | .succ t => succ (embedSharedTerm t)
  | .shareApp s r => app (embedSharedTerm s) (embedSharedTerm r)
  | .recur b s n => recur (embedSharedTerm b) (embedSharedTerm s) (embedSharedTerm n)

/-- Every embedded sharing-aware term lies in the closed fragment. -/
theorem embedSharedTerm_closedFragment :
    ∀ t : SharedTerm, HOClosedFragment (embedSharedTerm t)
  | .base => HOClosedFragment.base
  | .succ t => HOClosedFragment.succ (embedSharedTerm_closedFragment t)
  | .shareApp s r =>
      HOClosedFragment.app (embedSharedTerm_closedFragment s) (embedSharedTerm_closedFragment r)
  | .recur b s n =>
      HOClosedFragment.recur
        (embedSharedTerm_closedFragment b)
        (embedSharedTerm_closedFragment s)
        (embedSharedTerm_closedFragment n)

/-- The duplicating recursor source shape is a closed fragment of the higher-order carrier. -/
theorem shared_recursor_shape_closed_fragment
    (b s n : SharedTerm) :
    HOClosedFragment (embedSharedTerm (SharedTerm.recur b s (SharedTerm.succ n))) :=
  embedSharedTerm_closedFragment _

/-- Policy-indexed duplicating step in the minimal higher-order carrier. -/
inductive HODupStep : SharingPolicy → HOTerm → HOTerm → Prop
  | rec_succ (policy : SharingPolicy) (b s n : HOTerm) :
      HODupStep policy (recur b s (succ n)) (app s (recur b s n))

/-- Policy-sensitive direct counter. Under tree semantics the application node
counts both branches; under shared semantics it counts only the recursive
continuation. -/
@[simp] def HOPolicyCounter : SharingPolicy → HOTerm → Nat
  | _, base => 0
  | policy, succ t => HOPolicyCounter policy t + 1
  | .tree, app f a => HOPolicyCounter .tree f + HOPolicyCounter .tree a
  | .shared, app _ a => HOPolicyCounter .shared a
  | policy, recur _ _ n => HOPolicyCounter policy n

/-- The shared-policy counter agrees with the existing sharing-aware counter on
the embedded first-order surrogate. -/
@[simp] theorem shared_policy_counter_embed
    (t : SharedTerm) :
    HOPolicyCounter .shared (embedSharedTerm t) = sharedCounter t := by
  induction t with
  | base => rfl
  | succ t ih =>
      simpa [embedSharedTerm, HOPolicyCounter, sharedCounter] using congrArg Nat.succ ih
  | shareApp s r ihs ihr =>
      simpa [embedSharedTerm, HOPolicyCounter, sharedCounter] using ihr
  | recur b s n ihb ihs ihn =>
      simpa [embedSharedTerm, HOPolicyCounter, sharedCounter] using ihn

/-- The embedded sharing-aware step is a shared-policy higher-order step. -/
theorem shared_step_embeds
    {a b : SharedTerm} (h : SharedStep a b) :
    HODupStep .shared (embedSharedTerm a) (embedSharedTerm b) := by
  cases h with
  | rec_succ b s n =>
      simpa [embedSharedTerm] using
        (HODupStep.rec_succ .shared (embedSharedTerm b) (embedSharedTerm s) (embedSharedTerm n))

/-- Reused orientation fact from the sharing-aware surrogate, now stated on the
embedded higher-order shared step. -/
theorem shared_policy_counter_orients_embedded_step
    {a b : SharedTerm} (h : SharedStep a b) :
    HOPolicyCounter .shared (embedSharedTerm b) <
      HOPolicyCounter .shared (embedSharedTerm a) := by
  simpa using sharedCounter_orients_step h

/-- The shared-policy counter strictly decreases on every shared duplicating step. -/
abbrev HOPolicyOrientsStep (policy : SharingPolicy) : Prop :=
  ∀ {a b : HOTerm}, HODupStep policy a b → HOPolicyCounter policy b < HOPolicyCounter policy a

/-- The shared-policy counter orients the shared duplicating step. -/
theorem shared_policy_counter_orients_step :
    HOPolicyOrientsStep .shared := by
  intro a b h
  cases h
  simp [HOPolicyCounter]

/-- Any claim that the tree-based barrier lifts unchanged to every sharing
policy. The theorem below shows that this overclaims: the shared policy is a
counterexample. -/
abbrev UnqualifiedHigherOrderLiftClaim : Prop :=
  ∀ policy : SharingPolicy, ¬ HOPolicyOrientsStep policy

/-- The existing sharing-aware counterexample survives in the higher-order
carrier through the embedding. -/
theorem higher_order_fragment_recovers_sharing_breaks_tree_barrier
    (b s n : SharedTerm) :
    HOPolicyCounter .shared
      (embedSharedTerm (SharedTerm.shareApp s (SharedTerm.recur b s n))) <
    HOPolicyCounter .shared
      (embedSharedTerm (SharedTerm.recur b s (SharedTerm.succ n))) := by
  rw [shared_policy_counter_embed, shared_policy_counter_embed]
  exact sharing_breaks_tree_barrier b s n

/-- An unqualified higher-order lift that denies orientation for every sharing
policy contradicts the shared-policy orienting counter. -/
theorem unqualified_higher_order_lift_contradiction
    (h : UnqualifiedHigherOrderLiftClaim) : False :=
  h .shared shared_policy_counter_orients_step

/-- The tree/no-sharing hypothesis is load-bearing: once the policy admits
sharing, the shared-policy counter blocks any unqualified lift of the tree
barrier. -/
theorem sharing_policy_blocks_unqualified_tree_barrier_lift :
    ¬ UnqualifiedHigherOrderLiftClaim := by
  intro h
  exact unqualified_higher_order_lift_contradiction h

end OperatorKO7.HigherOrderSharingBoundary
