import OperatorKO7.Meta.Rewriting.Orthogonality

/-!
# Tait/Martin-Lof parallel reduction for first-order term rewriting systems

Roadmap source: the confluence-toolkit expansion atop the verified rewriting
foundation (`Term`, `Subst`, `Rewrite`, `Orthogonality`). This module adds
Tait/Martin-Lof parallel reduction `ParStep R`, the relation that contracts a set of
pairwise non-overlapping redexes in one sweep, situates it exactly between a single
rewrite step and a finite rewrite sequence, and proves it stable under substitution.

## What this module delivers

Parallel reduction (priority 1):

- `ParStep R` : the parallel one-step reduction of `R`, contracting non-overlapping
  redexes simultaneously. A variable parallel-reduces to itself; an application
  parallel-reduces argument-wise through the list companion `ParStepList R`; and a
  matching rule instance parallel-reduces inside its substitution, contracting the
  root redex while parallel-reducing the substituted terms. It is reflexive
  (`ParStep.refl`).

Sandwich between `Step` and `StepStar` (priority 2, the floor):

- `step_imp_parStep` : a single rewrite step is a parallel step.
- `parStep_imp_stepStar` : a parallel step is a finite rewrite sequence.
- `reflTransGen_parStep_eq_stepStar` : the reflexive-transitive closures of
  `Step R` and `ParStep R` coincide, so confluence of one is confluence of the
  other.

Parallel reduction is stable under substitution:

- `parStep_subst` : if `s` parallel-reduces to `s'` and each `σ x` parallel-reduces
  to `σ' x`, then `σ • s` parallel-reduces to `σ' • s'`. This is the substitution
  lemma that aligns parallel contractions, the engine of the complete-development
  argument.

Non-vacuity:

- `ParStep.demo_root` / `ParStep.demo_app` : concrete parallel steps over the
  demonstration system, one contracting a root redex and one reducing inside an
  argument, exhibiting the relation as genuinely inhabited.

Trust: kernel-only; baseline-only under `#print axioms` (a subset of
`{propext, Classical.choice, Quot.sound}`). Any `Classical.choice`/`propext`
dependence is from `Finset`/`DecidableEq` plumbing inherited through the foundation
modules.
-/

set_option autoImplicit false

namespace OperatorKO7.Meta.Rewriting

open scoped Subst
open Subst
open Relation

universe u v

variable {sigma : Type u} {nu : Type v}

/-! ## Priority 1: parallel reduction

`ParStep R` contracts a set of pairwise non-overlapping redexes in one sweep. The
mutual companion `ParStepList R` parallel-reduces an argument list position-wise. A
variable reduces to itself (reflexivity at the leaves); an application reduces
argument-wise; and a rule instance `σ • rule.lhs` contracts at the root to
`τ • rule.rhs`, where `τ` parallel-reduces the substituted terms of `σ`. The root
constructor parallel-reducing inside the matching substitution is the device that
makes a complete development expressible in one step. -/

mutual
/-- Parallel one-step reduction generated by `R`: contracts pairwise
non-overlapping redexes simultaneously. Reflexive on variables, congruent through
applications via `ParStepList`, and at a rule instance contracts the root redex
while parallel-reducing the substituted terms. -/
inductive ParStep (R : TRS sigma nu) : Term sigma nu → Term sigma nu → Prop
  | var (x : nu) : ParStep R (.var x) (.var x)
  | app (f : sigma) {args args' : List (Term sigma nu)} :
      ParStepList R args args' → ParStep R (.app f args) (.app f args')
  | root {rule : Rule sigma nu} (hrule : rule ∈ R) (σ σ' : Subst sigma nu)
      (h : ∀ x, ParStep R (σ x) (σ' x)) :
      ParStep R (σ • rule.lhs) (σ' • rule.rhs)
/-- Position-wise parallel reduction of an argument list: the list companion of
`ParStep`. -/
inductive ParStepList (R : TRS sigma nu) :
    List (Term sigma nu) → List (Term sigma nu) → Prop
  | nil : ParStepList R [] []
  | cons {a a' : Term sigma nu} {as as' : List (Term sigma nu)} :
      ParStep R a a' → ParStepList R as as' → ParStepList R (a :: as) (a' :: as')
end

/-! ## Reflexivity

Both relations are reflexive: a term parallel-reduces to itself. The proof is the
structural induction supplied by `Term.rec'`, which hands the per-argument
reflexivity needed to build the list reflexivity in the `app` case. -/

mutual
/-- A term parallel-reduces to itself. -/
theorem ParStep.refl (R : TRS sigma nu) : ∀ (t : Term sigma nu), ParStep R t t
  | .var x => ParStep.var x
  | .app f args => ParStep.app f (ParStepList.refl R args)
/-- An argument list parallel-reduces to itself. -/
theorem ParStepList.refl (R : TRS sigma nu) :
    ∀ (args : List (Term sigma nu)), ParStepList R args args
  | [] => ParStepList.nil
  | a :: as => ParStepList.cons (ParStep.refl R a) (ParStepList.refl R as)
end

/-- `ParStepList R` is the position-wise lift of `ParStep R`: it relates two lists
exactly when they have the same length and corresponding entries are related. The
forward direction (extracting the entry-wise relation and equal length) is what the
congruence proofs consume. -/
theorem ParStepList.length_eq {R : TRS sigma nu} :
    ∀ {as as' : List (Term sigma nu)}, ParStepList R as as' → as.length = as'.length
  | _, _, ParStepList.nil => rfl
  | _, _, ParStepList.cons _ ht => by rw [List.length_cons, List.length_cons, ht.length_eq]

/-! ## Priority 2 (FLOOR): the sandwich between `Step` and `StepStar`

A single rewrite step is a parallel step that contracts exactly one redex, and a
parallel step is realized by a finite rewrite sequence. Hence the
reflexive-transitive closures of `Step R` and `ParStep R` coincide, and any
confluence statement transfers between the two relations. -/

/-- A single rewrite step is a parallel step. The root case contracts the one redex
with the identity parallel reduction on the substitution; the argument case lifts
the inductive parallel step through the list, leaving the siblings fixed by
reflexivity. -/
theorem step_imp_parStep (R : TRS sigma nu) {s t : Term sigma nu} (h : Step R s t) :
    ParStep R s t := by
  induction h with
  | @root s t hroot =>
      obtain ⟨rule, hrule, σ, hs, ht⟩ := hroot
      subst hs; subst ht
      exact ParStep.root hrule σ σ (fun x => ParStep.refl R (σ x))
  | @arg f pre post a b _hstep ih =>
      refine ParStep.app f ?_
      -- the parallel step sits at the `a`/`b` slot; the prefix and suffix are fixed
      have hpre : ParStepList R pre pre := ParStepList.refl R pre
      have hpost : ParStepList R post post := ParStepList.refl R post
      clear _hstep
      induction pre with
      | nil => exact ParStepList.cons ih hpost
      | cons c cs ihc =>
          cases hpre with
          | cons hc hcs => exact ParStepList.cons hc (ihc hcs)

/-- A rewrite sequence lifts through one argument slot of a fixed head, leaving the
prefix and suffix fixed: if `a ↠ b` then `app f (pre ++ a :: post) ↠ app f (pre ++ b :: post)`.
This is `StepStar.arg_congr`, restated for the assembly below. -/
private theorem stepStar_arg_slot (R : TRS sigma nu) (f : sigma)
    (pre post : List (Term sigma nu)) {a b : Term sigma nu} (h : StepStar R a b) :
    StepStar R (.app f (pre ++ a :: post)) (.app f (pre ++ b :: post)) :=
  StepStar.arg_congr R f pre post h

/-- The list realization, accumulated slot by slot: a `ParStepList R as as'` gives a
finite rewrite sequence from `app f (done ++ as)` to `app f (done ++ as')`, for every
head `f` and reduced prefix `done`. Proved by the mutual recursor `ParStep.rec` with
the term motive `StepStar R a a'`, so the recursion descends both the list spine and
the entry-wise parallel steps in one structural pass. The recursor is the supported
route for these inductive predicates, where direct mutual structural recursion is
not available. -/
theorem parStepList_imp_stepStar_app (R : TRS sigma nu) :
    ∀ {as as' : List (Term sigma nu)}, ParStepList R as as' →
      ∀ (f : sigma) (done : List (Term sigma nu)),
        StepStar R (.app f (done ++ as)) (.app f (done ++ as')) := by
  intro as as' h
  refine ParStepList.rec (R := R)
    (motive_1 := fun a a' _ => StepStar R a a')
    (motive_2 := fun as as' _ => ∀ (f : sigma) (done : List (Term sigma nu)),
      StepStar R (.app f (done ++ as)) (.app f (done ++ as')))
    ?var ?app ?root ?nil ?cons h
  · -- variable: reflexivity
    intro x; exact StepStar.refl R _
  · -- application: the argument-wise sequence with empty prefix, at this head
    intro g _ _ _ ih
    have := ih g []
    simpa using this
  · -- root: one contraction then the pointwise replay over `rhs`
    intro rule hrule σ σ' _ ih
    have hroot : StepStar R (σ • rule.lhs) (σ • rule.rhs) :=
      StepStar.single (Step.rootStep_step R hrule σ)
    have htail : StepStar R (σ • rule.rhs) (σ' • rule.rhs) :=
      stepStar_of_pointwise_stepStar R (fun x => ih x) rule.rhs
    exact hroot.trans htail
  · -- empty list: reflexivity at every head and prefix
    intro f done; exact StepStar.refl R _
  · -- cons: reduce the head slot, then recurse on the tail with the head appended
    intro a a' as as' _ha _has ihHead ihTail f done
    have h1 : StepStar R (.app f (done ++ a :: as)) (.app f (done ++ a' :: as)) :=
      stepStar_arg_slot R f done as ihHead
    have h2 : StepStar R (.app f ((done ++ [a']) ++ as)) (.app f ((done ++ [a']) ++ as')) :=
      ihTail f (done ++ [a'])
    have he1 : done ++ a' :: as = (done ++ [a']) ++ as := by simp
    have he2 : (done ++ [a']) ++ as' = done ++ a' :: as' := by simp
    rw [he1] at h1
    rw [he2] at h2
    exact h1.trans h2

/-- A parallel step is realized by a finite rewrite sequence: `ParStep R s t` gives
`StepStar R s t`. The variable case is reflexivity; the application case reduces
argument-wise through `parStepList_imp_stepStar_app`; the root case contracts the
redex in one step `σ • rule.lhs → σ • rule.rhs` and then replays the substitution's
parallel reductions across `rule.rhs` by `stepStar_of_pointwise_stepStar`. -/
theorem parStep_imp_stepStar (R : TRS sigma nu) {s t : Term sigma nu}
    (h : ParStep R s t) : StepStar R s t := by
  -- the list motive is irrelevant here: the application case is closed outright by
  -- the standalone `parStepList_imp_stepStar_app`, so `motive_2` is taken trivial
  refine ParStep.rec (R := R)
    (motive_1 := fun a a' _ => StepStar R a a')
    (motive_2 := fun _ _ _ => True)
    ?var ?app ?root trivial (fun _ _ _ _ => trivial) h
  · intro x; exact StepStar.refl R _
  · intro g args args' hlist _ih
    have := parStepList_imp_stepStar_app R hlist g []
    simpa using this
  · intro rule hrule σ σ' _ ih
    have hroot : StepStar R (σ • rule.lhs) (σ • rule.rhs) :=
      StepStar.single (Step.rootStep_step R hrule σ)
    have htail : StepStar R (σ • rule.rhs) (σ' • rule.rhs) :=
      stepStar_of_pointwise_stepStar R (fun x => ih x) rule.rhs
    exact hroot.trans htail

/-- A list-level parallel step is realized by a finite rewrite sequence on the
application built from the two lists, the empty-accumulator instance of
`parStepList_imp_stepStar_app`. -/
theorem parStepList_imp_stepStar (R : TRS sigma nu) {as as' : List (Term sigma nu)}
    (h : ParStepList R as as') (f : sigma) :
    StepStar R (.app f as) (.app f as') := by
  have := parStepList_imp_stepStar_app R h f []
  simpa using this

/-! ## The closures coincide

`Step R ⊆ ParStep R ⊆ StepStar R`, so taking reflexive-transitive closures gives
`ReflTransGen (Step R) = ReflTransGen (ParStep R)`. Since `StepStar R` is by
definition `ReflTransGen (Step R)`, the closure of parallel reduction is exactly the
ordinary rewrite relation. -/

/-- The reflexive-transitive closure of `ParStep R` is contained in that of `Step R`:
each parallel step expands to a rewrite sequence by `parStep_imp_stepStar`. -/
theorem reflTransGen_parStep_le_stepStar (R : TRS sigma nu) {s t : Term sigma nu}
    (h : ReflTransGen (ParStep R) s t) : StepStar R s t := by
  induction h with
  | refl => exact StepStar.refl R _
  | tail _ hstep ih => exact ih.trans (parStep_imp_stepStar R hstep)

/-- The reflexive-transitive closure of `Step R` is contained in that of `ParStep R`:
each rewrite step is a single parallel step by `step_imp_parStep`. -/
theorem stepStar_le_reflTransGen_parStep (R : TRS sigma nu) {s t : Term sigma nu}
    (h : StepStar R s t) : ReflTransGen (ParStep R) s t :=
  h.mono (fun _ _ hstep => step_imp_parStep R hstep)

/-- The reflexive-transitive closures of `Step R` and `ParStep R` coincide. Parallel
reduction sits between a single step and a finite rewrite sequence, so iterating it
generates exactly the ordinary rewrite relation. Consequently every confluence
statement transfers between the two relations. -/
theorem reflTransGen_parStep_eq_stepStar (R : TRS sigma nu) :
    ReflTransGen (ParStep R) = StepStar R := by
  funext s t
  exact propext ⟨reflTransGen_parStep_le_stepStar R, stepStar_le_reflTransGen_parStep R⟩

/-! ## Parallel reduction is stable under substitution

The substitution lemma for parallel reduction: a parallel step survives applying
parallel-reducing substitutions to both sides. It is the engine that aligns the two
parallel contractions in the diamond argument. The root case is where the
substitutions compose: `σ • (δ • rule.lhs) = (σ ∘ δ) • rule.lhs` by `apply_comp`, so
the contracted instance reappears under the composite substitution, whose images
parallel-reduce by the induction hypothesis. This holds for every system, with no
linearity assumption. -/

/-- Parallel reduction is stable under parallel-reducing substitutions: if
`ParStep R s s'` and every `σ x` parallel-reduces to `σ' x`, then `σ • s`
parallel-reduces to `σ' • s'`. The variable case is the substitution hypothesis; the
application case lifts position-wise; the root case recomposes the substitutions
through `apply_comp` and parallel-reduces the composite images by the induction
hypothesis. -/
theorem parStep_subst (R : TRS sigma nu) {σ σ' : Subst sigma nu}
    (hσ : ∀ x, ParStep R (σ x) (σ' x)) {s s' : Term sigma nu} (h : ParStep R s s') :
    ParStep R (σ • s) (σ' • s') := by
  refine ParStep.rec (R := R)
    (motive_1 := fun a a' _ => ParStep R (σ • a) (σ' • a'))
    (motive_2 := fun as as' _ => ParStepList R (applyList σ as) (applyList σ' as'))
    ?var ?app ?root ?nil ?cons h
  · -- variable: `σ • var x = σ x`, `σ' • var x = σ' x`
    intro x; simpa using hσ x
  · -- application: lift the list reduction under the same head
    intro f args args' _hlist ih
    rw [apply_app, apply_app]
    exact ParStep.app f ih
  · -- root: recompose the substitutions, reduce the composite images by `ih`
    intro rule hrule δ δ' _hδ ih
    rw [← apply_comp, ← apply_comp]
    -- the composite substitutions feeding the rule, with parallel-reduced images
    exact ParStep.root hrule (comp σ δ) (comp σ' δ') (fun x => by
      simpa only [comp_apply_var] using ih x)
  · -- empty list
    exact ParStepList.nil
  · -- cons: head reduces by the term motive, tail by the list motive
    intro a a' as as' _ha _has ihHead ihTail
    rw [applyList_cons, applyList_cons]
    exact ParStepList.cons ihHead ihTail

/-! ## Non-vacuity

The parallel relation is inhabited by concrete steps over the one-rule
demonstration system `Example.demoTRS` (`f(x) -> g(x)`). One step contracts the root
redex `f(c)` to `g(c)`; another reduces that same redex inside the argument of
`h(f(c))`, exercising the `app` constructor on a genuine context. Both are real
parallel steps, exhibiting `ParStep` as genuinely inhabited. -/

namespace ParStep

/-- A concrete root parallel step: `f(c)` parallel-reduces to `g(c)` by contracting
the root redex of the demonstration rule, with the identity parallel reduction on the
substituted constant. -/
theorem demo_root :
    ParStep Example.demoTRS Example.srcTerm Example.tgtTerm := by
  have h : ParStep Example.demoTRS (Example.demoSubst • Example.demoRule.lhs)
      (Example.demoSubst • Example.demoRule.rhs) :=
    ParStep.root (List.mem_singleton.2 rfl) Example.demoSubst Example.demoSubst
      (fun x => ParStep.refl Example.demoTRS (Example.demoSubst x))
  simpa only [Example.apply_lhs, Example.apply_rhs] using h

/-- A concrete contextual parallel step: the redex `f(c)` parallel-reduces inside the
argument position of `h(f(c))`, giving `h(f(c))` parallel-reduces to `h(g(c))`. This
exercises the `app` constructor on a genuine context, with the root step at the
single argument. -/
theorem demo_app :
    ParStep Example.demoTRS (.app 3 [Example.srcTerm]) (.app 3 [Example.tgtTerm]) :=
  ParStep.app 3 (ParStepList.cons demo_root ParStepList.nil)

end ParStep

end OperatorKO7.Meta.Rewriting

