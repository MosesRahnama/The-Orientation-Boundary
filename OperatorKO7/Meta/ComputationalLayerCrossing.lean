import OperatorKO7.Meta.SchemaCanonicalTrace
import OperatorKO7.Meta.InformationAccess
import OperatorKO7.Meta.FreeStepDuplicatingSyntax
import OperatorKO7.Meta.SchemaOperationalIncompleteness

/-!
# Computational Layer Crossing

This module formalizes the computation-to-record bridge suggested by the
Failure Floor structural-identity discussion.

The core object is a `RecordEmissionWitness` for a fixed base/step seed pair
inside a `BaseDuplicatingSystem`. Such a witness supplies:

- a live-computation coordinate that stays constant along the canonical live
  computation stages and vanishes at the terminal record, and
- a record coordinate that grows exactly with the progress index and therefore
  decodes that hidden index from the emitted record family.

From this we derive a concrete `MetaAccessModel` in the sense of
`Meta/InformationAccess.lean`:

- the live channel is not directly verdict-retrieving once there are at least
  two possible progress indices; but
- the record channel retrieves the hidden progress index exactly.

This is the formal computation-side "layer crossing" used to tighten the
structural-identity bridge.
-/

namespace OperatorKO7.StepDuplicating

namespace StepDuplicatingSchema
namespace BaseDuplicatingSystem

open OperatorKO7.InformationAccess

variable {Sys : BaseDuplicatingSystem}

/-- A fixed-seed record-emission witness for the canonical trace generated by
`recur b s (succ^k base)`.

The witness exposes two observable coordinates:

- `liveCoord`: present during the live computation stages and gone at the
  terminal record;
- `recordCoord`: the emitted record depth, which recovers the hidden progress
  index exactly.
-/
structure RecordEmissionWitness (Sys : BaseDuplicatingSystem) (b s : Sys.T) where
  liveCoord : Sys.T → Nat
  recordCoord : Sys.T → Nat
  live_at_canonical :
    ∀ k i, i ≤ k → liveCoord (Sys.canonicalTrace b s k i) = 1
  record_at_canonical :
    ∀ k i, i ≤ k → recordCoord (Sys.canonicalTrace b s k i) = i
  live_at_terminal :
    ∀ k, liveCoord (Sys.wrapChain s k b) = 0
  record_at_terminal :
    ∀ k, recordCoord (Sys.wrapChain s k b) = k

namespace RecordEmissionWitness

variable {b s : Sys.T} (W : RecordEmissionWitness Sys b s)

@[simp] theorem live_canonical (k i : Nat) (hik : i ≤ k) :
    W.liveCoord (Sys.canonicalTrace b s k i) = 1 :=
  W.live_at_canonical k i hik

@[simp] theorem record_canonical (k i : Nat) (hik : i ≤ k) :
    W.recordCoord (Sys.canonicalTrace b s k i) = i :=
  W.record_at_canonical k i hik

@[simp] theorem live_terminal (k : Nat) :
    W.liveCoord (Sys.wrapChain s k b) = 0 :=
  W.live_at_terminal k

@[simp] theorem record_terminal (k : Nat) :
    W.recordCoord (Sys.wrapChain s k b) = k :=
  W.record_at_terminal k

/-- Along the canonical live computation, the control coordinate and the record
coordinate sum to the initial counter depth. -/
theorem control_record_conservation (k i : Nat) (hik : i ≤ k) :
    BaseDuplicatingSystem.trace_ctr k i
      + W.recordCoord (Sys.canonicalTrace b s k i) = k := by
  unfold BaseDuplicatingSystem.trace_ctr
  rw [W.record_canonical k i hik]
  omega

/-- The emitted record coordinate increases by exactly one per canonical step. -/
theorem record_grows_one_per_step (k i : Nat) (hik : i < k) :
    W.recordCoord (Sys.canonicalTrace b s k (i + 1))
      = W.recordCoord (Sys.canonicalTrace b s k i) + 1 := by
  calc
    W.recordCoord (Sys.canonicalTrace b s k (i + 1))
        = i + 1 := by rw [W.record_canonical k (i + 1) (by omega)]
    _ = W.recordCoord (Sys.canonicalTrace b s k i) + 1 := by
      rw [W.record_canonical k i (by omega)]

/-- The live coordinate is constant across all canonical live stages. -/
theorem live_coordinate_constant (k i j : Nat) (hik : i ≤ k) (hjk : j ≤ k) :
    W.liveCoord (Sys.canonicalTrace b s k i)
      = W.liveCoord (Sys.canonicalTrace b s k j) := by
  rw [W.live_canonical k i hik, W.live_canonical k j hjk]

/-- The exact record coordinate makes the canonical live stages injective in
their progress index. -/
theorem record_coordinate_stage_injective (k : Nat) :
    Function.Injective
      (fun i : Fin (k + 1) =>
        W.recordCoord (Sys.canonicalTrace b s k i.1)) := by
  intro i j hij
  apply Fin.ext
  have hi :
      W.recordCoord (Sys.canonicalTrace b s k i.1) = i.1 := by
    exact W.record_canonical k i.1 (Nat.le_of_lt_succ i.2)
  have hj :
      W.recordCoord (Sys.canonicalTrace b s k j.1) = j.1 := by
    exact W.record_canonical k j.1 (Nat.le_of_lt_succ j.2)
  simpa [hi, hj] using hij

/-- The live computation channel is not stage-injective once at least two
progress indices are available. -/
theorem live_coordinate_not_stage_injective {k : Nat} (hk : 1 ≤ k) :
    ¬ Function.Injective
      (fun i : Fin (k + 1) =>
        W.liveCoord (Sys.canonicalTrace b s k i.1)) := by
  intro hinj
  let i0 : Fin (k + 1) := ⟨0, Nat.succ_pos _⟩
  let i1 : Fin (k + 1) := ⟨1, by omega⟩
  have hsame :
      W.liveCoord (Sys.canonicalTrace b s k i0.1)
        = W.liveCoord (Sys.canonicalTrace b s k i1.1) := by
    rw [W.live_canonical k i0.1 (by omega), W.live_canonical k i1.1 (by omega)]
  have hij := hinj hsame
  have : (0 : Nat) = 1 := by
    simpa [i0, i1] using congrArg Fin.val hij
  omega

/-- The terminal record family is injective in the emitted record depth. -/
theorem terminal_record_family_injective (W' : RecordEmissionWitness Sys b s) :
    Function.Injective (fun k : Nat => Sys.wrapChain s k b) := by
  intro k l hkl
  have hEq : Sys.wrapChain s k b = Sys.wrapChain s l b := by
    simpa using hkl
  have hk :=
    OperatorKO7.StepDuplicating.StepDuplicatingSchema.BaseDuplicatingSystem.RecordEmissionWitness.record_at_terminal
      W' k
  have hl :=
    OperatorKO7.StepDuplicating.StepDuplicatingSchema.BaseDuplicatingSystem.RecordEmissionWitness.record_at_terminal
      W' l
  rw [hEq] at hk
  exact hk.symm.trans hl

/-- The live computation and the terminal record are observationally separated:
the live coordinate is present on the live stages and absent on the terminal
record. -/
theorem live_terminal_separation (k i : Nat) (hik : i ≤ k) :
    W.liveCoord (Sys.canonicalTrace b s k i)
      ≠ W.liveCoord (Sys.wrapChain s k b) := by
  rw [W.live_canonical k i hik, W.live_terminal k]
  decide

/-- Access model in which the hidden verdict is the progress index itself:

- at stage `0`, the meta layer sees only the live computation coordinate;
- at stage `1`, it sees the emitted record coordinate.

This makes the computation-to-record crossing explicit inside the generic
Section 2 access framework. -/
def liveRecordAccessModel (K : Nat) :
    MetaAccessModel (Fin (K + 1)) Unit (Fin (K + 1)) Nat where
  metaView := fun _ => ()
  verdict := fun i => i
  trace
    | 0 => fun i => W.liveCoord (Sys.canonicalTrace b s i.1 0)
    | _ + 1 => fun i => W.recordCoord (Sys.wrapChain s i.1 b)

@[simp] theorem liveRecordAccessModel_trace_zero (K : Nat) (i : Fin (K + 1)) :
    (W.liveRecordAccessModel K).trace 0 i = 1 := by
  change W.liveCoord (Sys.canonicalTrace b s i.1 0) = 1
  exact W.live_canonical i.1 0 (Nat.zero_le _)

@[simp] theorem liveRecordAccessModel_trace_succ (K n : Nat) (i : Fin (K + 1)) :
    (W.liveRecordAccessModel K).trace (n + 1) i = i.1 := by
  simp [liveRecordAccessModel, W.record_terminal]

/-- The record channel decodes the hidden progress index exactly. -/
theorem liveRecordAccess_stage1_retrieval (K : Nat) :
    AccessibleFrom
      ((W.liveRecordAccessModel K).stageAccess 1)
      (W.liveRecordAccessModel K).verdict := by
  refine ⟨fun mt => ⟨Nat.min mt.2 K, by
    exact lt_of_le_of_lt (Nat.min_le_right _ _) (Nat.lt_succ_self K)⟩, ?_⟩
  funext i
  apply Fin.ext
  simp [MetaAccessModel.stageAccess, liveRecordAccessModel,
    Nat.min_eq_left (Nat.le_of_lt_succ i.2)]

/-- The live computation channel does not directly retrieve the progress index
once there are at least two admissible depths. -/
theorem liveRecordAccess_not_directRetrieval {K : Nat} (hK : 1 ≤ K) :
    ¬ (W.liveRecordAccessModel K).DirectRetrieval := by
  intro hdirect
  rcases hdirect with ⟨decode, hdecode⟩
  let i0 : Fin (K + 1) := ⟨0, Nat.succ_pos _⟩
  let i1 : Fin (K + 1) := ⟨1, by omega⟩
  have hsame :
      (W.liveRecordAccessModel K).initialAccess i0
        = (W.liveRecordAccessModel K).initialAccess i1 := by
    apply Prod.ext
    · rfl
    · simp [MetaAccessModel.initialAccess]
  have hdecodeEq : (W.liveRecordAccessModel K).verdict i0
      = (W.liveRecordAccessModel K).verdict i1 := by
    rw [hdecode]
    exact congrArg decode hsame
  have hvals : i0.1 = i1.1 := by
    exact congrArg Fin.val hdecodeEq
  have : (0 : Nat) = 1 := by
    simp [i0, i1] at hvals
  omega

/-- The record-emission witness realizes a genuine sequential uncertainty
reduction event: the live channel is not directly verdict-retrieving, but the
record channel is. -/
theorem liveRecordAccess_sequentialReduction {K : Nat} (hK : 1 ≤ K) :
    (W.liveRecordAccessModel K).SequentialUncertaintyReduction 1 := by
  refine ⟨W.liveRecordAccess_not_directRetrieval hK, ?_⟩
  simpa using W.liveRecordAccess_stage1_retrieval K

/-- The hidden progress index is genuinely hidden from the meta layer alone and
becomes accessible only through the emitted record coordinate. -/
theorem liveRecordAccess_requires_hidden_state {K : Nat} (hK : 1 ≤ K) :
    ∃ φ : Fin (K + 1) → Nat,
      ¬ OperatorKO7.InformationAccess.AccessibleFrom
          (W.liveRecordAccessModel K).metaView φ
        ∧ OperatorKO7.InformationAccess.AccessibleFrom
            (fun x => ((W.liveRecordAccessModel K).metaView x, φ x))
            (W.liveRecordAccessModel K).verdict := by
  simpa using
    MetaAccessModel.sequential_resolution_requires_hidden_state
      (A := W.liveRecordAccessModel K)
      (hseq := W.liveRecordAccess_sequentialReduction hK)

/-- Named predicate for the computation-to-record crossing event. -/
def RealizesComputationToRecordCrossing (K : Nat) : Prop :=
  (W.liveRecordAccessModel K).SequentialUncertaintyReduction 1

theorem realizesComputationToRecordCrossing_of_one_le {K : Nat} (hK : 1 ≤ K) :
    W.RealizesComputationToRecordCrossing K := by
  exact W.liveRecordAccess_sequentialReduction hK

end RecordEmissionWitness

/-- A more semantic version of record emission. Instead of starting from
numeric coordinates directly, this interface assumes:

- a live observable with a distinguished live token and terminal token; and
- a record observable equipped with a decoder for the hidden progress index.

From this we can recover a concrete `RecordEmissionWitness`. -/
structure FaithfulRecordEmitter (Sys : BaseDuplicatingSystem) (b s : Sys.T) where
  LiveObs : Type
  liveObsDecEq : DecidableEq LiveObs
  RecordObs : Type
  liveObs : Sys.T → LiveObs
  recordObs : Sys.T → RecordObs
  liveToken : LiveObs
  terminalToken : LiveObs
  decodeRecord : RecordObs → Nat
  live_at_canonical :
    ∀ k i, i ≤ k → liveObs (Sys.canonicalTrace b s k i) = liveToken
  live_at_terminal :
    ∀ k, liveObs (Sys.wrapChain s k b) = terminalToken
  live_token_ne_terminal : liveToken ≠ terminalToken
  decode_record_at_canonical :
    ∀ k i, i ≤ k → decodeRecord (recordObs (Sys.canonicalTrace b s k i)) = i
  decode_record_at_terminal :
    ∀ k, decodeRecord (recordObs (Sys.wrapChain s k b)) = k

namespace FaithfulRecordEmitter

variable {b s : Sys.T} (E : FaithfulRecordEmitter Sys b s)

/-- Any faithful record emitter induces a concrete record-emission witness. -/
def toRecordEmissionWitness : RecordEmissionWitness Sys b s where
  liveCoord := fun t =>
    letI := E.liveObsDecEq
    if E.liveObs t = E.liveToken then 1 else 0
  recordCoord := fun t => E.decodeRecord (E.recordObs t)
  live_at_canonical := by
    intro k i hik
    letI := E.liveObsDecEq
    simp [E.live_at_canonical k i hik]
  record_at_canonical := by
    intro k i hik
    simpa using E.decode_record_at_canonical k i hik
  live_at_terminal := by
    intro k
    letI := E.liveObsDecEq
    have hneq : E.terminalToken ≠ E.liveToken := by
      intro h
      exact E.live_token_ne_terminal h.symm
    simp [E.live_at_terminal k, hneq]
  record_at_terminal := by
    intro k
    simpa using E.decode_record_at_terminal k

theorem realizesComputationToRecordCrossing_of_one_le {K : Nat} (hK : 1 ≤ K) :
    (E.toRecordEmissionWitness).RealizesComputationToRecordCrossing K := by
  exact (E.toRecordEmissionWitness).realizesComputationToRecordCrossing_of_one_le hK

theorem requires_hidden_state {K : Nat} (hK : 1 ≤ K) :
    ∃ φ : Fin (K + 1) → Nat,
      ¬ OperatorKO7.InformationAccess.AccessibleFrom
          ((E.toRecordEmissionWitness).liveRecordAccessModel K).metaView φ
        ∧ OperatorKO7.InformationAccess.AccessibleFrom
            (fun x => (((E.toRecordEmissionWitness).liveRecordAccessModel K).metaView x, φ x))
            ((E.toRecordEmissionWitness).liveRecordAccessModel K).verdict := by
  exact (E.toRecordEmissionWitness).liveRecordAccess_requires_hidden_state hK

end FaithfulRecordEmitter

/-- A semantic projection kernel on the ambient carrier. Unlike the explicit
stage-indexed extension principle, this object is constructor-driven: it gives
an ambient projection map together with a projection rank on the ambient schema
view, and requires the projection map itself to respect the step-duplicating
constructors in the generator-tracking way needed for the canonical trace.

This is the right abstract replacement for per-stage extension data when the
ambient carrier already comes with a semantically meaningful projection. -/
structure SemanticProjectionKernel (Sys : BaseDuplicatingSystem) where
  project : Sys.T → Sys.T
  projectedRank : ProjectionRank Sys.toStepDuplicatingSchema
  project_base : project Sys.base = Sys.base
  project_succ : ∀ t, project (Sys.succ t) = Sys.succ (project t)
  /-- Wrapper payload is forgotten while the recursive continuation is kept. -/
  project_wrap : ∀ x y, project (Sys.wrap x y) = project y
  project_recur :
    ∀ b s n, project (Sys.recur b s n) =
      Sys.recur (project b) (project s) (project n)

namespace SemanticProjectionKernel

variable (K : SemanticProjectionKernel Sys)

/-- Extensionality for semantic projection kernels by their projection map and
projected rank. -/
@[ext] theorem ext
    (K₁ K₂ : SemanticProjectionKernel Sys)
    (hproj : K₁.project = K₂.project)
    (hrank : K₁.projectedRank = K₂.projectedRank) :
    K₁ = K₂ := by
  cases K₁
  cases K₂
  cases hproj
  cases hrank
  simp

@[simp] theorem project_counter (n : Nat) :
    K.project (Sys.counter n) = Sys.counter n := by
  induction n with
  | zero =>
      simpa [BaseDuplicatingSystem.counter] using K.project_base
  | succ n ih =>
      change K.project (Sys.succ (Sys.counter n)) = Sys.succ (Sys.counter n)
      rw [K.project_succ, ih]

@[simp] theorem project_wrapChain (s : Sys.T) (i : Nat) (t : Sys.T) :
    K.project (Sys.wrapChain s i t) = K.project t := by
  induction i generalizing t with
  | zero =>
      simp [BaseDuplicatingSystem.wrapChain]
  | succ i ih =>
      simp [BaseDuplicatingSystem.wrapChain, K.project_wrap, ih]

@[simp] theorem projectedRank_counter (n : Nat) :
    K.projectedRank.rank (K.project (Sys.counter n)) = n := by
  rw [K.project_counter n]
  induction n with
  | zero =>
      simpa [BaseDuplicatingSystem.counter] using K.projectedRank.rank_base
  | succ n ih =>
      change K.projectedRank.rank (Sys.succ (Sys.counter n)) = n + 1
      rw [K.projectedRank.rank_succ, ih]

@[simp] theorem projectedRank_canonical
    {b s : Sys.T} (k i : Nat) (_hik : i ≤ k) :
    K.projectedRank.rank (K.project (Sys.canonicalTrace b s k i))
      = BaseDuplicatingSystem.trace_ctr k i := by
  rw [BaseDuplicatingSystem.canonicalTrace, K.project_wrapChain s i]
  rw [K.project_recur]
  rw [K.projectedRank.rank_recur]
  simpa [BaseDuplicatingSystem.trace_ctr] using K.projectedRank_counter (k - i)

@[simp] theorem projectedRank_terminal
    {b s : Sys.T} (k : Nat) :
    K.projectedRank.rank (K.project (Sys.wrapChain s k b)) = K.projectedRank.rank (K.project b) := by
  rw [K.project_wrapChain s k b]

/-- On a carrier generated by the step-duplicating constructors, the ambient
projection map of a semantic kernel is uniquely determined by the kernel
equations. -/
theorem project_unique_of_generated
    {Sys : BaseDuplicatingSystem}
    (G : GeneratedByConstructors Sys.toStepDuplicatingSchema)
    (K₁ K₂ : SemanticProjectionKernel Sys) :
    K₁.project = K₂.project := by
  funext t
  let P : Sys.T → Prop := fun u => K₁.project u = K₂.project u
  have hbaseP : P Sys.base := by
    dsimp [P]
    simp [K₁.project_base, K₂.project_base]
  have hsuccP : ∀ u, P u → P (Sys.succ u) := by
    intro u hu
    dsimp [P] at hu ⊢
    rw [K₁.project_succ, K₂.project_succ, hu]
  have hwrapP : ∀ x y, P x → P y → P (Sys.wrap x y) := by
    intro x y _ hy
    dsimp [P] at hy ⊢
    rw [K₁.project_wrap, K₂.project_wrap, hy]
  have hrecurP : ∀ b s n, P b → P s → P n → P (Sys.recur b s n) := by
    intro b s n hb hs hn
    dsimp [P] at hb hs hn ⊢
    rw [K₁.project_recur, K₂.project_recur, hb, hs, hn]
  exact G.generated hbaseP hsuccP hwrapP hrecurP t

/-- Hence the whole semantic kernel is unique on any constructor-generated
carrier. -/
theorem unique_of_generated
    {Sys : BaseDuplicatingSystem}
    (G : GeneratedByConstructors Sys.toStepDuplicatingSchema)
    (K₁ K₂ : SemanticProjectionKernel Sys) :
    K₁ = K₂ := by
  apply SemanticProjectionKernel.ext
  · exact project_unique_of_generated G K₁ K₂
  · exact projectionRank_unique_of_generated G K₁.projectedRank K₂.projectedRank

end SemanticProjectionKernel

/-- A genuine constructor-recursion principle for the ambient carrier.
Unlike `GeneratedByConstructors`, this is strong enough to *define* ambient
functions out of `Sys.T` by giving their constructor equations. This is the
missing hypothesis behind the remaining raw-emitter ambient-staticity gap:
without some interface of this kind, the raw emitter data alone does not let
Lean build the ambient projection map or rank on an arbitrary carrier. -/
structure ConstructorRecursor (Sys : BaseDuplicatingSystem) where
  fold :
    {α : Type} →
      α →
      (α → α) →
      (α → α → α) →
      (α → α → α → α) →
      Sys.T → α
  fold_base :
    ∀ {α : Type} (z : α) (hs : α → α)
      (hw : α → α → α) (hr : α → α → α → α),
      fold z hs hw hr Sys.base = z
  fold_succ :
    ∀ {α : Type} (z : α) (hs : α → α)
      (hw : α → α → α) (hr : α → α → α → α) (t : Sys.T),
      fold z hs hw hr (Sys.succ t) = hs (fold z hs hw hr t)
  fold_wrap :
    ∀ {α : Type} (z : α) (hs : α → α)
      (hw : α → α → α) (hr : α → α → α → α) (x y : Sys.T),
      fold z hs hw hr (Sys.wrap x y) =
        hw (fold z hs hw hr x) (fold z hs hw hr y)
  fold_recur :
    ∀ {α : Type} (z : α) (hs : α → α)
      (hw : α → α → α) (hr : α → α → α → α) (b s n : Sys.T),
      fold z hs hw hr (Sys.recur b s n) =
        hr (fold z hs hw hr b) (fold z hs hw hr s) (fold z hs hw hr n)

namespace ConstructorRecursor

variable (R : ConstructorRecursor Sys)

/-- Canonical ambient projection obtained by erasing the wrapper constructor
through the constructor-recursion principle. -/
def project : Sys.T → Sys.T :=
  R.fold Sys.base Sys.succ (fun _ y => y) Sys.recur

@[simp] theorem project_base :
    R.project Sys.base = Sys.base := by
  simpa [project] using
    R.fold_base (α := Sys.T) Sys.base Sys.succ (fun _ y => y) Sys.recur

@[simp] theorem project_succ (t : Sys.T) :
    R.project (Sys.succ t) = Sys.succ (R.project t) := by
  simpa [project] using
    R.fold_succ (α := Sys.T) Sys.base Sys.succ (fun _ y => y) Sys.recur t

@[simp] theorem project_wrap (x y : Sys.T) :
    R.project (Sys.wrap x y) = R.project y := by
  simpa [project] using
    R.fold_wrap (α := Sys.T) Sys.base Sys.succ (fun _ y => y) Sys.recur x y

@[simp] theorem project_recur (b s n : Sys.T) :
    R.project (Sys.recur b s n) =
      Sys.recur (R.project b) (R.project s) (R.project n) := by
  simpa [project] using
    R.fold_recur (α := Sys.T) Sys.base Sys.succ (fun _ y => y) Sys.recur b s n

/-- Canonical projection-rank function obtained from the same constructor
recursion principle. -/
def projectedRankFn : Sys.T → Nat :=
  R.fold 0 (fun n => n + 1) (fun _ _ => 0) (fun _ _ n => n)

@[simp] theorem projectedRankFn_base :
    R.projectedRankFn Sys.base = 0 := by
  simpa [projectedRankFn] using
    R.fold_base (α := Nat) 0 (fun n => n + 1) (fun _ _ => 0) (fun _ _ n => n)

@[simp] theorem projectedRankFn_succ (t : Sys.T) :
    R.projectedRankFn (Sys.succ t) = R.projectedRankFn t + 1 := by
  simpa [projectedRankFn, Nat.add_comm] using
    R.fold_succ (α := Nat) 0 (fun n => n + 1) (fun _ _ => 0) (fun _ _ n => n) t

@[simp] theorem projectedRankFn_wrap (x y : Sys.T) :
    R.projectedRankFn (Sys.wrap x y) = 0 := by
  simpa [projectedRankFn] using
    R.fold_wrap (α := Nat) 0 (fun n => n + 1) (fun _ _ => 0) (fun _ _ n => n) x y

@[simp] theorem projectedRankFn_recur (b s n : Sys.T) :
    R.projectedRankFn (Sys.recur b s n) = R.projectedRankFn n := by
  simpa [projectedRankFn] using
    R.fold_recur (α := Nat) 0 (fun n => n + 1) (fun _ _ => 0) (fun _ _ n => n) b s n

/-- The constructor-recursion principle canonically determines the unique
projection rank compatible with the step-duplicating equations. -/
def projectedRank : ProjectionRank Sys.toStepDuplicatingSchema where
  rank := R.projectedRankFn
  rank_base := R.projectedRankFn_base
  rank_succ := R.projectedRankFn_succ
  rank_wrap := R.projectedRankFn_wrap
  rank_recur := R.projectedRankFn_recur

/-- Therefore a constructor-recursion principle canonically yields the full
ambient semantic projection kernel. -/
def toSemanticProjectionKernel : SemanticProjectionKernel Sys where
  project := R.project
  projectedRank := R.projectedRank
  project_base := R.project_base
  project_succ := R.project_succ
  project_wrap := R.project_wrap
  project_recur := R.project_recur

end ConstructorRecursor

/-- A weaker projection-kernel interface. Unlike `SemanticProjectionKernel`,
this object only controls the projected rank after projection, not the
projected term itself. This is the right weaker abstract hypothesis when the
ambient projection is semantically meaningful only through the generator rank
it induces. -/
structure RankLevelProjectionKernel (Sys : BaseDuplicatingSystem) where
  project : Sys.T → Sys.T
  projectedRank : ProjectionRank Sys.toStepDuplicatingSchema
  projected_base : projectedRank.rank (project Sys.base) = 0
  projected_succ :
    ∀ t, projectedRank.rank (project (Sys.succ t))
      = projectedRank.rank (project t) + 1
  projected_wrap :
    ∀ x y, projectedRank.rank (project (Sys.wrap x y))
      = projectedRank.rank (project y)
  projected_recur :
    ∀ b s n, projectedRank.rank (project (Sys.recur b s n))
      = projectedRank.rank (project n)

namespace RankLevelProjectionKernel

variable (K : RankLevelProjectionKernel Sys)

/-- Every semantic projection kernel induces a rank-level kernel. -/
def ofSemanticProjectionKernel (K' : SemanticProjectionKernel Sys) :
    RankLevelProjectionKernel Sys where
  project := K'.project
  projectedRank := K'.projectedRank
  projected_base := by
    simpa [K'.project_base] using K'.projectedRank.rank_base
  projected_succ := by
    intro t
    rw [K'.project_succ, K'.projectedRank.rank_succ]
  projected_wrap := by
    intro x y
    rw [K'.project_wrap]
  projected_recur := by
    intro b s n
    rw [K'.project_recur, K'.projectedRank.rank_recur]

@[simp] theorem projectedRank_counter (n : Nat) :
    K.projectedRank.rank (K.project (Sys.counter n)) = n := by
  induction n with
  | zero =>
      simpa [BaseDuplicatingSystem.counter] using K.projected_base
  | succ n ih =>
      change K.projectedRank.rank (K.project (Sys.succ (Sys.counter n))) = n + 1
      rw [K.projected_succ, ih]

@[simp] theorem projectedRank_wrapChain (s : Sys.T) (i : Nat) (t : Sys.T) :
    K.projectedRank.rank (K.project (Sys.wrapChain s i t))
      = K.projectedRank.rank (K.project t) := by
  induction i generalizing t with
  | zero =>
      simp [BaseDuplicatingSystem.wrapChain]
  | succ i ih =>
      rw [BaseDuplicatingSystem.wrapChain, K.projected_wrap, ih]

@[simp] theorem projectedRank_canonical
    {b s : Sys.T} (k i : Nat) (_hik : i ≤ k) :
    K.projectedRank.rank (K.project (Sys.canonicalTrace b s k i))
      = BaseDuplicatingSystem.trace_ctr k i := by
  rw [BaseDuplicatingSystem.canonicalTrace, K.projectedRank_wrapChain s i]
  rw [K.projected_recur]
  simp [BaseDuplicatingSystem.trace_ctr, K.projectedRank_counter]

@[simp] theorem projectedRank_terminal
    {b s : Sys.T} (k : Nat) :
    K.projectedRank.rank (K.project (Sys.wrapChain s k b))
      = K.projectedRank.rank (K.project b) := by
  rw [K.projectedRank_wrapChain s k b]

end RankLevelProjectionKernel

/-- A record emitter equipped with an explicit projection to the generator-side
counter rank. This is the critic-facing bridge from the computation-to-record
layer crossing to the confession / forgetting stack: the emitted record carries
progress externally, while a licensed projection recovers the hidden generator
coordinate internally. -/
structure ProjectiveRecordEmitter (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends FaithfulRecordEmitter Sys b s where
  project : Sys.T → Sys.T
  projectedRank : ProjectionRank Sys.toStepDuplicatingSchema
  project_canonical :
    ∀ k i, i ≤ k →
      projectedRank.rank (project (Sys.canonicalTrace b s k i))
        = BaseDuplicatingSystem.trace_ctr k i
  project_terminal :
    ∀ k,
      projectedRank.rank (project (Sys.wrapChain s k b)) = 0

namespace ProjectiveRecordEmitter

variable {b s : Sys.T} (E : ProjectiveRecordEmitter Sys b s)

/-- The projected generator coordinate obtained by applying the licensed
projection and then reading the projection rank. -/
def projectedGeneratorCoord (t : Sys.T) : Nat :=
  E.projectedRank.rank (E.project t)

@[simp] theorem projectedGenerator_at_canonical (k i : Nat) (hik : i ≤ k) :
    E.projectedGeneratorCoord (Sys.canonicalTrace b s k i)
      = BaseDuplicatingSystem.trace_ctr k i := by
  exact E.project_canonical k i hik

@[simp] theorem projectedGenerator_at_terminal (k : Nat) :
    E.projectedGeneratorCoord (Sys.wrapChain s k b) = 0 := by
  exact E.project_terminal k

/-- Along the canonical trace, the projected generator coordinate and the
emitted record coordinate complement each other exactly. -/
theorem projectedGenerator_record_conservation (k i : Nat) (hik : i ≤ k) :
    E.projectedGeneratorCoord (Sys.canonicalTrace b s k i)
      + (E.toRecordEmissionWitness).recordCoord (Sys.canonicalTrace b s k i) = k := by
  rw [E.projectedGenerator_at_canonical k i hik,
    (E.toRecordEmissionWitness).record_canonical k i hik]
  simp [BaseDuplicatingSystem.trace_ctr]
  omega

/-- The projected generator coordinate drops by exactly one per canonical
successor step. -/
theorem projectedGenerator_drops_one_per_step (k i : Nat) (hik : i < k) :
    E.projectedGeneratorCoord (Sys.canonicalTrace b s k (i + 1)) + 1
      = E.projectedGeneratorCoord (Sys.canonicalTrace b s k i) := by
  rw [E.projectedGenerator_at_canonical k (i + 1) (by omega),
    E.projectedGenerator_at_canonical k i (by omega)]
  simp [BaseDuplicatingSystem.trace_ctr]
  omega

/-- The underlying projection rank yields the generic forgetting witness. -/
def toForgettingWitness : ForgettingWitness Sys.toStepDuplicatingSchema :=
  ForgettingWitness.ofProjectionRank E.projectedRank

/-- The same projection rank yields the Paper-2 operational-incompleteness
bundle on the ambient step-duplicating system view. -/
def toOperationalIncompleteness :
    OperationalIncompleteness Sys.toStepDuplicatingSystem :=
  OperationalIncompleteness.ofProjectionRank E.projectedRank

/-- A projective record emitter determines a projection-transaction once a
license proposition is fixed. -/
def toProjectionTransaction (license : Prop) (hlicense : license) :
    ProjectionTransaction Sys.toStepDuplicatingSchema where
  dimension := E.projectedGeneratorCoord
  license := license
  boundary := E.toForgettingWitness
  licensed := hlicense

/-- Named critic-facing bridge: a single projective emitter witnesses both the
computation-to-record crossing and the confession-style forgetting package. -/
def RealizesComputationToConfessionBridge (K : Nat) : Prop :=
  (E.toRecordEmissionWitness).RealizesComputationToRecordCrossing K
    ∧ Nonempty (OperationalIncompleteness Sys.toStepDuplicatingSystem)

theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    E.RealizesComputationToConfessionBridge K := by
  refine ⟨E.realizesComputationToRecordCrossing_of_one_le hK, ?_⟩
  exact ⟨E.toOperationalIncompleteness⟩

end ProjectiveRecordEmitter

/-- A more semantic generator-preserving emitter. Compared with
`ProjectiveRecordEmitter`, this interface does not assume a packaged
`ProjectionRank`; it only gives a generator coordinate satisfying the
projection-rank equations after projection. From this data we can reconstruct
the projective/confession bridge canonically. -/
structure GeneratorPreservingRecordEmitter
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends FaithfulRecordEmitter Sys b s where
  project : Sys.T → Sys.T
  generatorCoord : Sys.T → Nat
  generator_base : generatorCoord Sys.base = 0
  generator_succ : ∀ t, generatorCoord (Sys.succ t) = generatorCoord t + 1
  generator_wrap : ∀ x y, generatorCoord (Sys.wrap x y) = 0
  generator_recur : ∀ b s n, generatorCoord (Sys.recur b s n) = generatorCoord n
  project_canonical :
    ∀ k i, i ≤ k →
      generatorCoord (project (Sys.canonicalTrace b s k i))
        = BaseDuplicatingSystem.trace_ctr k i
  project_terminal :
    ∀ k,
      generatorCoord (project (Sys.wrapChain s k b)) = 0

namespace GeneratorPreservingRecordEmitter

variable {b s : Sys.T} (E : GeneratorPreservingRecordEmitter Sys b s)

/-- The generator coordinate canonically packages to a projection rank. -/
def toProjectionRank : ProjectionRank Sys.toStepDuplicatingSchema where
  rank := E.generatorCoord
  rank_base := E.generator_base
  rank_succ := E.generator_succ
  rank_wrap := E.generator_wrap
  rank_recur := E.generator_recur

/-- Every generator-preserving emitter induces a projective emitter. -/
def toProjectiveRecordEmitter : BaseDuplicatingSystem.ProjectiveRecordEmitter Sys b s where
  toFaithfulRecordEmitter := E.toFaithfulRecordEmitter
  project := E.project
  projectedRank := E.toProjectionRank
  project_canonical := E.project_canonical
  project_terminal := E.project_terminal

theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    (toProjectiveRecordEmitter E).RealizesComputationToConfessionBridge K := by
  exact (toProjectiveRecordEmitter E).realizesComputationToConfessionBridge_of_one_le hK

end GeneratorPreservingRecordEmitter

/-- A semantically coherent generator-preserving emitter. This is strictly
weaker than supplying a `SemanticProjectionKernel` as separate data: it starts
from the generator-preserving emitter interface and only adds the fact that the
ambient projection itself respects the step-duplicating constructors. From this
the semantic kernel can be reconstructed canonically. -/
structure SemanticGeneratorPreservingRecordEmitter
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends GeneratorPreservingRecordEmitter Sys b s where
  project_base : project Sys.base = Sys.base
  project_succ : ∀ t, project (Sys.succ t) = Sys.succ (project t)
  project_wrap : ∀ x y, project (Sys.wrap x y) = project y
  project_recur :
    ∀ b s n, project (Sys.recur b s n) =
      Sys.recur (project b) (project s) (project n)

namespace SemanticGeneratorPreservingRecordEmitter

variable {b s : Sys.T} (E : SemanticGeneratorPreservingRecordEmitter Sys b s)

/-- The coherent projection data canonically packages to a semantic projection
kernel. -/
def toSemanticProjectionKernel : SemanticProjectionKernel Sys where
  project := E.project
  projectedRank := E.toGeneratorPreservingRecordEmitter.toProjectionRank
  project_base := E.project_base
  project_succ := E.project_succ
  project_wrap := E.project_wrap
  project_recur := E.project_recur

/-- The semantic generator-preserving emitter still induces the same concrete
projective emitter as its underlying generator-preserving interface. -/
def toProjectiveRecordEmitter : BaseDuplicatingSystem.ProjectiveRecordEmitter Sys b s :=
  E.toGeneratorPreservingRecordEmitter.toProjectiveRecordEmitter

/-- Hence the coherent generator-preserving emitter already determines the full
projective/confession bridge. -/
theorem realizesComputationToConfessionBridge_of_one_le {K : Nat}
    (hK : 1 ≤ K) :
    (E.toProjectiveRecordEmitter).RealizesComputationToConfessionBridge K := by
  exact E.toGeneratorPreservingRecordEmitter.realizesComputationToConfessionBridge_of_one_le hK

end SemanticGeneratorPreservingRecordEmitter

/-- A weaker semantic precursor than `GeneratorPreservingRecordEmitter`.
It does not assume a separate generator coordinate as primitive data; instead
it gives a projection together with a raw projected rank satisfying the
generator equations after projection. This is enough to reconstruct the full
generator-preserving bridge. -/
structure ProjectedGeneratorWitness
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends FaithfulRecordEmitter Sys b s where
  project : Sys.T → Sys.T
  projectedRankFn : Sys.T → Nat
  projected_base : projectedRankFn Sys.base = 0
  projected_succ :
    ∀ t, projectedRankFn (Sys.succ t) = projectedRankFn t + 1
  projected_wrap :
    ∀ x y, projectedRankFn (Sys.wrap x y) = 0
  projected_recur :
    ∀ b s n, projectedRankFn (Sys.recur b s n) = projectedRankFn n
  project_canonical :
    ∀ k i, i ≤ k →
      projectedRankFn (project (Sys.canonicalTrace b s k i))
        = BaseDuplicatingSystem.trace_ctr k i
  project_terminal :
    ∀ k,
      projectedRankFn (project (Sys.wrapChain s k b)) = 0

namespace ProjectedGeneratorWitness

variable {b s : Sys.T} (W : ProjectedGeneratorWitness Sys b s)

/-- Every projected generator witness induces a generator-preserving emitter. -/
def toGeneratorPreservingRecordEmitter :
    BaseDuplicatingSystem.GeneratorPreservingRecordEmitter Sys b s where
  toFaithfulRecordEmitter := W.toFaithfulRecordEmitter
  project := W.project
  generatorCoord := W.projectedRankFn
  generator_base := W.projected_base
  generator_succ := W.projected_succ
  generator_wrap := W.projected_wrap
  generator_recur := W.projected_recur
  project_canonical := W.project_canonical
  project_terminal := W.project_terminal

/-- And therefore it also induces the full projective/confession bridge. -/
def toProjectiveRecordEmitter :
    BaseDuplicatingSystem.ProjectiveRecordEmitter Sys b s :=
  BaseDuplicatingSystem.GeneratorPreservingRecordEmitter.toProjectiveRecordEmitter
    (toGeneratorPreservingRecordEmitter W)

theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (W.toProjectiveRecordEmitter) K := by
  exact
    BaseDuplicatingSystem.GeneratorPreservingRecordEmitter.realizesComputationToConfessionBridge_of_one_le
      (W.toGeneratorPreservingRecordEmitter) hK

end ProjectedGeneratorWitness

/-- A weaker semantic precursor than `ProjectedGeneratorWitness`.
Instead of assuming the exact projected generator coordinate along the canonical
trace, this interface only assumes the conservation law saying that the
projected generator coordinate and the emitted record depth sum to the original
counter depth. Since the record channel already decodes the progress index
exactly, the projected counter value can then be recovered algebraically. -/
structure ConservationBasedGeneratorEmitter
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends FaithfulRecordEmitter Sys b s where
  project : Sys.T → Sys.T
  projectedRankFn : Sys.T → Nat
  projected_base : projectedRankFn Sys.base = 0
  projected_succ :
    ∀ t, projectedRankFn (Sys.succ t) = projectedRankFn t + 1
  projected_wrap :
    ∀ x y, projectedRankFn (Sys.wrap x y) = 0
  projected_recur :
    ∀ b s n, projectedRankFn (Sys.recur b s n) = projectedRankFn n
  conservation_at_canonical :
    ∀ k i, i ≤ k →
      projectedRankFn (project (Sys.canonicalTrace b s k i))
        + decodeRecord (recordObs (Sys.canonicalTrace b s k i)) = k
  conservation_at_terminal :
    ∀ k,
      projectedRankFn (project (Sys.wrapChain s k b))
        + decodeRecord (recordObs (Sys.wrapChain s k b)) = k

namespace ConservationBasedGeneratorEmitter

variable {b s : Sys.T} (E : ConservationBasedGeneratorEmitter Sys b s)

/-- The canonical projected generator value is recovered from the conservation
law together with exact record decoding. -/
theorem project_canonical (k i : Nat) (hik : i ≤ k) :
    E.projectedRankFn (E.project (Sys.canonicalTrace b s k i))
      = BaseDuplicatingSystem.trace_ctr k i := by
  have hcons := E.conservation_at_canonical k i hik
  have hrec := E.decode_record_at_canonical k i hik
  rw [hrec] at hcons
  unfold BaseDuplicatingSystem.trace_ctr
  omega

/-- The terminal projected generator value is recovered similarly. -/
theorem project_terminal (k : Nat) :
    E.projectedRankFn (E.project (Sys.wrapChain s k b)) = 0 := by
  have hcons := E.conservation_at_terminal k
  have hrec := E.decode_record_at_terminal k
  rw [hrec] at hcons
  omega

/-- In particular, the projected base seed is already normalized. -/
theorem project_seed_zero :
    E.projectedRankFn (E.project b) = 0 := by
  simpa [BaseDuplicatingSystem.wrapChain] using E.project_terminal (b := b) (s := s) 0

/-- A conservation-based emitter induces the exact projected-generator witness. -/
def toProjectedGeneratorWitness :
    BaseDuplicatingSystem.ProjectedGeneratorWitness Sys b s where
  toFaithfulRecordEmitter := E.toFaithfulRecordEmitter
  project := E.project
  projectedRankFn := E.projectedRankFn
  projected_base := E.projected_base
  projected_succ := E.projected_succ
  projected_wrap := E.projected_wrap
  projected_recur := E.projected_recur
  project_canonical := E.project_canonical
  project_terminal := E.project_terminal

/-- Hence the conservation-based interface already induces the full
computation-to-confession bridge. -/
theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (E.toProjectedGeneratorWitness.toProjectiveRecordEmitter) K := by
  exact
    BaseDuplicatingSystem.ProjectedGeneratorWitness.realizesComputationToConfessionBridge_of_one_le
      (E.toProjectedGeneratorWitness) hK

end ConservationBasedGeneratorEmitter

/-- A weaker semantic precursor than `SemanticGeneratorPreservingRecordEmitter`.
It starts only from the conservation-law interface and adds constructor-respecting
coherence for the ambient projection itself. The exact canonical/terminal
projected generator equations are then recovered from conservation, not assumed
as primitive data. -/
structure SemanticConservationBasedGeneratorEmitter
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends ConservationBasedGeneratorEmitter Sys b s where
  project_base : project Sys.base = Sys.base
  project_succ : ∀ t, project (Sys.succ t) = Sys.succ (project t)
  project_wrap : ∀ x y, project (Sys.wrap x y) = project y
  project_recur :
    ∀ b s n, project (Sys.recur b s n) =
      Sys.recur (project b) (project s) (project n)

namespace SemanticConservationBasedGeneratorEmitter

variable {b s : Sys.T} (E : SemanticConservationBasedGeneratorEmitter Sys b s)

/-- The coherent conservation-based interface canonically packages to a
semantic projection kernel. -/
def toSemanticProjectionKernel : SemanticProjectionKernel Sys where
  project := E.project
  projectedRank := {
    rank := E.projectedRankFn
    rank_base := E.projected_base
    rank_succ := E.projected_succ
    rank_wrap := E.projected_wrap
    rank_recur := E.projected_recur
  }
  project_base := E.project_base
  project_succ := E.project_succ
  project_wrap := E.project_wrap
  project_recur := E.project_recur

/-- The same weaker semantic interface also induces the semantically coherent
generator-preserving emitter layer. -/
def toSemanticGeneratorPreservingRecordEmitter :
    BaseDuplicatingSystem.SemanticGeneratorPreservingRecordEmitter Sys b s where
  toGeneratorPreservingRecordEmitter := {
    toFaithfulRecordEmitter := E.toFaithfulRecordEmitter
    project := E.project
    generatorCoord := E.projectedRankFn
    generator_base := E.projected_base
    generator_succ := E.projected_succ
    generator_wrap := E.projected_wrap
    generator_recur := E.projected_recur
    project_canonical := E.project_canonical
    project_terminal := E.project_terminal
  }
  project_base := E.project_base
  project_succ := E.project_succ
  project_wrap := E.project_wrap
  project_recur := E.project_recur

/-- Hence the weaker semantic-conservation interface already determines the
full projective/confession bridge. -/
theorem realizesComputationToConfessionBridge_of_one_le {K : Nat}
    (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (BaseDuplicatingSystem.SemanticGeneratorPreservingRecordEmitter.toProjectiveRecordEmitter
        (E.toSemanticGeneratorPreservingRecordEmitter)) K := by
  exact
    BaseDuplicatingSystem.SemanticGeneratorPreservingRecordEmitter.realizesComputationToConfessionBridge_of_one_le
      (E.toSemanticGeneratorPreservingRecordEmitter) hK

end SemanticConservationBasedGeneratorEmitter

/-- A genuinely step-indexed precursor below the global conservation-law
interface. Instead of postulating a single ambient projected-rank function, it
only provides the projected generator coordinate along the canonical live trace
and at the terminal record. This is the right next-lower semantic layer for the
critic-facing "computation to record" story. -/
structure StageIndexedConservationEmitter
    (Sys : BaseDuplicatingSystem) (b s : Sys.T)
    extends FaithfulRecordEmitter Sys b s where
  projectedStageCoord : Nat → Nat → Nat
  projectedTerminalCoord : Nat → Nat
  conservation_at_canonical :
    ∀ k i, i ≤ k →
      projectedStageCoord k i
        + decodeRecord (recordObs (Sys.canonicalTrace b s k i)) = k
  conservation_at_terminal :
    ∀ k,
      projectedTerminalCoord k
        + decodeRecord (recordObs (Sys.wrapChain s k b)) = k

namespace StageIndexedConservationEmitter

variable {b s : Sys.T} (E : StageIndexedConservationEmitter Sys b s)

/-- The projected generator coordinate along the canonical live trace is
recovered purely from step-indexed conservation and exact record decoding. -/
theorem projectedStage_eq_trace_ctr (k i : Nat) (hik : i ≤ k) :
    E.projectedStageCoord k i = BaseDuplicatingSystem.trace_ctr k i := by
  have hcons := E.conservation_at_canonical k i hik
  have hrec := E.decode_record_at_canonical k i hik
  rw [hrec] at hcons
  unfold BaseDuplicatingSystem.trace_ctr
  omega

/-- The terminal projected generator coordinate vanishes. -/
theorem projectedTerminal_zero (k : Nat) :
    E.projectedTerminalCoord k = 0 := by
  have hcons := E.conservation_at_terminal k
  have hrec := E.decode_record_at_terminal k
  rw [hrec] at hcons
  omega

/-- Along the canonical live trace, the recovered projected generator
coordinate drops by exactly one per step. -/
theorem projectedStage_drops_one_per_step (k i : Nat) (hik : i < k) :
    E.projectedStageCoord k (i + 1) + 1 = E.projectedStageCoord k i := by
  rw [E.projectedStage_eq_trace_ctr k (i + 1) (by omega),
    E.projectedStage_eq_trace_ctr k i (by omega)]
  unfold BaseDuplicatingSystem.trace_ctr
  omega

/-- The step-indexed conservation interface still realizes the computation-to-
record crossing, because it already contains a faithful record emitter. -/
theorem realizesComputationToRecordCrossing_of_one_le {K : Nat} (hK : 1 ≤ K) :
    (E.toRecordEmissionWitness).RealizesComputationToRecordCrossing K := by
  exact E.toFaithfulRecordEmitter.realizesComputationToRecordCrossing_of_one_le hK

/-- An explicit extension principle lifting the stage-indexed conservation
interface to a global projected-rank function on the ambient carrier. This is
the exact bridge needed to turn local stage-by-stage generator recovery into
the stronger global conservation-law interface. -/
structure Extension
    (E : StageIndexedConservationEmitter Sys b s) where
  project : Sys.T → Sys.T
  projectedRankFn : Sys.T → Nat
  projected_base : projectedRankFn Sys.base = 0
  projected_succ :
    ∀ t, projectedRankFn (Sys.succ t) = projectedRankFn t + 1
  projected_wrap :
    ∀ x y, projectedRankFn (Sys.wrap x y) = 0
  projected_recur :
    ∀ b s n, projectedRankFn (Sys.recur b s n) = projectedRankFn n
  extends_canonical :
    ∀ k i, i ≤ k →
      projectedRankFn (project (Sys.canonicalTrace b s k i))
        = E.projectedStageCoord k i
  extends_terminal :
    ∀ k,
      projectedRankFn (project (Sys.wrapChain s k b))
        = E.projectedTerminalCoord k

namespace Extension

variable {E : StageIndexedConservationEmitter Sys b s} (X : E.Extension)

/-- Any explicit extension of the stage-indexed interface induces the global
conservation-law interface. -/
def toConservationBasedGeneratorEmitter :
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter Sys b s where
  toFaithfulRecordEmitter := E.toFaithfulRecordEmitter
  project := X.project
  projectedRankFn := X.projectedRankFn
  projected_base := X.projected_base
  projected_succ := X.projected_succ
  projected_wrap := X.projected_wrap
  projected_recur := X.projected_recur
  conservation_at_canonical := by
    intro k i hik
    rw [X.extends_canonical k i hik]
    exact E.conservation_at_canonical k i hik
  conservation_at_terminal := by
    intro k
    rw [X.extends_terminal k]
    exact E.conservation_at_terminal k

/-- Hence the stage-indexed interface plus an explicit extension principle
already induces the full computation-to-confession bridge. -/
theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (X.toConservationBasedGeneratorEmitter.toProjectedGeneratorWitness.toProjectiveRecordEmitter) K := by
  exact
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter.realizesComputationToConfessionBridge_of_one_le
      (X.toConservationBasedGeneratorEmitter) hK

end Extension

/-- A semantic strengthening of the raw stage-indexed extension principle.
Compared with `Extension`, this does not add projected-generator equations; it
only requires that the ambient extension projection itself respects the
step-duplicating constructors. Together with stage-indexed conservation, this
is enough to recover a semantic-kernel completion. -/
structure SemanticExtension
    (E : StageIndexedConservationEmitter Sys b s)
    extends E.Extension where
  project_base : project Sys.base = Sys.base
  project_succ : ∀ t, project (Sys.succ t) = Sys.succ (project t)
  project_wrap : ∀ x y, project (Sys.wrap x y) = project y
  project_recur :
    ∀ b s n, project (Sys.recur b s n) =
      Sys.recur (project b) (project s) (project n)

namespace SemanticExtension

variable {E : StageIndexedConservationEmitter Sys b s} (X : E.SemanticExtension)

/-- A semantic raw stage-indexed extension induces the weaker semantic
conservation-based interface. -/
def toSemanticConservationBasedGeneratorEmitter :
    BaseDuplicatingSystem.SemanticConservationBasedGeneratorEmitter Sys b s where
  toConservationBasedGeneratorEmitter := X.toConservationBasedGeneratorEmitter
  project_base := X.project_base
  project_succ := X.project_succ
  project_wrap := X.project_wrap
  project_recur := X.project_recur

/-- Hence the semantic raw stage-indexed extension already determines the full
projective/confession bridge. -/
theorem realizesComputationToConfessionBridge_of_one_le {K : Nat} (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (BaseDuplicatingSystem.SemanticGeneratorPreservingRecordEmitter.toProjectiveRecordEmitter
        (X.toSemanticConservationBasedGeneratorEmitter.toSemanticGeneratorPreservingRecordEmitter)) K := by
  exact
    BaseDuplicatingSystem.SemanticConservationBasedGeneratorEmitter.realizesComputationToConfessionBridge_of_one_le
      (X.toSemanticConservationBasedGeneratorEmitter) hK

end SemanticExtension

/-- A direct canonical-shadow carrier for the stage-indexed interface. -/
inductive ShadowObservation
  | live (k i : Nat) (hik : i ≤ k)
  | terminal (k : Nat)

/-- Direct canonical-shadow conservation profile extracted from the stage-
indexed interface, with no separately postulated ambient extension principle. -/
structure CanonicalShadowConservationInterface where
  materialize : ShadowObservation → Sys.T
  projectedCoord : ShadowObservation → Nat
  recordCoord : ShadowObservation → Nat
  conservation_live :
    ∀ k i (hik : i ≤ k),
      projectedCoord (.live k i hik) + recordCoord (.live k i hik) = k
  conservation_terminal :
    ∀ k,
      projectedCoord (.terminal k) + recordCoord (.terminal k) = k
  projected_live :
    ∀ k i (hik : i ≤ k),
      projectedCoord (.live k i hik) = BaseDuplicatingSystem.trace_ctr k i
  projected_terminal :
    ∀ k, projectedCoord (.terminal k) = 0

/-- The stage-indexed interface directly induces a global conservation profile
on the canonical trace shadow. -/
def toCanonicalShadowConservationInterface :
    CanonicalShadowConservationInterface (Sys := Sys) where
  materialize
    | .live k i hik => Sys.canonicalTrace b s k i
    | .terminal k => Sys.wrapChain s k b
  projectedCoord
    | .live k i hik => E.projectedStageCoord k i
    | .terminal k => E.projectedTerminalCoord k
  recordCoord
    | .live k i hik => E.decodeRecord (E.recordObs (Sys.canonicalTrace b s k i))
    | .terminal k => E.decodeRecord (E.recordObs (Sys.wrapChain s k b))
  conservation_live := by
    intro k i hik
    exact E.conservation_at_canonical k i hik
  conservation_terminal := by
    intro k
    exact E.conservation_at_terminal k
  projected_live := by
    intro k i hik
    exact E.projectedStage_eq_trace_ctr k i hik
  projected_terminal := by
    intro k
    exact E.projectedTerminal_zero k

end StageIndexedConservationEmitter

namespace FaithfulRecordEmitter

variable {b s : Sys.T} (E : FaithfulRecordEmitter Sys b s)

/-- If the ambient carrier already comes with a semantic projection kernel
whose projected base seed is normalized, then any faithful record emitter
induces the ambient conservation-law interface directly. This avoids the
separate stage-indexed extension axiom entirely. -/
def toConservationBasedGeneratorEmitterOfSemanticKernel
    (K : SemanticProjectionKernel Sys)
    (hprojBase : K.projectedRank.rank (K.project b) = 0) :
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter Sys b s where
  toFaithfulRecordEmitter := E
  project := K.project
  projectedRankFn := K.projectedRank.rank
  projected_base := K.projectedRank.rank_base
  projected_succ := K.projectedRank.rank_succ
  projected_wrap := K.projectedRank.rank_wrap
  projected_recur := K.projectedRank.rank_recur
  conservation_at_canonical := by
    intro k i hik
    rw [K.projectedRank_canonical (b := b) (s := s) k i hik]
    rw [E.decode_record_at_canonical k i hik]
    simp [BaseDuplicatingSystem.trace_ctr]
    omega
  conservation_at_terminal := by
    intro k
    rw [K.projectedRank_terminal (b := b) (s := s) k]
    rw [hprojBase, E.decode_record_at_terminal k]
    omega

/-- Hence a faithful record emitter plus a semantic ambient projection kernel
already yields the full computation-to-confession bridge. -/
theorem realizesComputationToConfessionBridge_of_semanticKernel {Kdepth : Nat}
    (K : SemanticProjectionKernel Sys)
    (hprojBase : K.projectedRank.rank (K.project b) = 0)
    (hK : 1 ≤ Kdepth) :
    let C :=
      BaseDuplicatingSystem.FaithfulRecordEmitter.toConservationBasedGeneratorEmitterOfSemanticKernel
        (E := E) K hprojBase
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (C.toProjectedGeneratorWitness.toProjectiveRecordEmitter) Kdepth := by
  exact
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter.realizesComputationToConfessionBridge_of_one_le
      (BaseDuplicatingSystem.FaithfulRecordEmitter.toConservationBasedGeneratorEmitterOfSemanticKernel
        (E := E) K hprojBase) hK

/-- The same bridge already follows from the weaker rank-level kernel
hypothesis. This is the real weaker abstract form: only the generator-rank
behavior of the projection matters for the bridge, not exact term-level
constructor equations of the projected image. -/
def toConservationBasedGeneratorEmitterOfRankLevelKernel
    (K : RankLevelProjectionKernel Sys)
    (hprojBase : K.projectedRank.rank (K.project b) = 0) :
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter Sys b s where
  toFaithfulRecordEmitter := E
  project := K.project
  projectedRankFn := K.projectedRank.rank
  projected_base := K.projectedRank.rank_base
  projected_succ := K.projectedRank.rank_succ
  projected_wrap := K.projectedRank.rank_wrap
  projected_recur := K.projectedRank.rank_recur
  conservation_at_canonical := by
    intro k i hik
    rw [K.projectedRank_canonical (b := b) (s := s) k i hik]
    rw [E.decode_record_at_canonical k i hik]
    simp [BaseDuplicatingSystem.trace_ctr]
    omega
  conservation_at_terminal := by
    intro k
    rw [K.projectedRank_terminal (b := b) (s := s) k]
    rw [hprojBase, E.decode_record_at_terminal k]
    omega

theorem realizesComputationToConfessionBridge_of_rankLevelKernel {Kdepth : Nat}
    (K : RankLevelProjectionKernel Sys)
    (hprojBase : K.projectedRank.rank (K.project b) = 0)
    (hK : 1 ≤ Kdepth) :
    let C :=
      BaseDuplicatingSystem.FaithfulRecordEmitter.toConservationBasedGeneratorEmitterOfRankLevelKernel
        (E := E) K hprojBase
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      (C.toProjectedGeneratorWitness.toProjectiveRecordEmitter) Kdepth := by
  exact
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter.realizesComputationToConfessionBridge_of_one_le
      (BaseDuplicatingSystem.FaithfulRecordEmitter.toConservationBasedGeneratorEmitterOfRankLevelKernel
        (E := E) K hprojBase) hK

end FaithfulRecordEmitter

end BaseDuplicatingSystem

/-! ## Concrete free-syntax instance -/

open BaseDuplicatingSystem

/-- Root rewrite relation for the free primitive step-duplicating syntax with
both the duplicating successor step and the terminal base step. -/
inductive FreeBaseStep : FreeTerm → FreeTerm → Prop
  | base (b s : FreeTerm) : FreeBaseStep (.recur b s .base) b
  | dup (b s n : FreeTerm) :
      FreeBaseStep (.recur b s (.succ n)) (.wrap s (.recur b s n))

/-- The free syntax packaged as a base-duplicating system. -/
def freeBaseSystem : BaseDuplicatingSystem where
  toStepDuplicatingSystem := {
    toStepDuplicatingSchema := freeSchema
    Step := FreeBaseStep
    dup_step := by
      intro b s n
      exact FreeBaseStep.dup b s n
  }
  base_step := by
    intro b s
    exact FreeBaseStep.base b s

/-- Canonical base seed for the free record-emission instance. -/
def freeSeedX : freeBaseSystem.T := FreeTerm.base

/-- Canonical step/payload seed for the free record-emission instance. -/
def freeSeedY : freeBaseSystem.T := FreeTerm.succ FreeTerm.base

/-- Count active `recur` sites in the free syntax. -/
def freeLiveCoord : freeBaseSystem.T → Nat
  | .base => 0
  | .succ t => freeLiveCoord t
  | .wrap x y => freeLiveCoord x + freeLiveCoord y
  | .recur b s n => freeLiveCoord b + freeLiveCoord s + freeLiveCoord n + 1

/-- Count emitted wrapper layers in the free syntax. -/
def freeRecordCoord : freeBaseSystem.T → Nat
  | .base => 0
  | .succ t => freeRecordCoord t
  | .wrap x y => freeRecordCoord x + freeRecordCoord y + 1
  | .recur b s n => freeRecordCoord b + freeRecordCoord s + freeRecordCoord n

@[simp] theorem freeLiveCoord_base : freeLiveCoord FreeTerm.base = 0 := rfl

@[simp] theorem freeLiveCoord_seedY : freeLiveCoord freeSeedY = 0 := rfl

@[simp] theorem freeRecordCoord_base : freeRecordCoord FreeTerm.base = 0 := rfl

@[simp] theorem freeRecordCoord_seedY : freeRecordCoord freeSeedY = 0 := rfl

@[simp] theorem freeLiveCoord_counter (k : Nat) :
    freeLiveCoord (freeBaseSystem.counter k) = 0 := by
  induction k with
  | zero => rfl
  | succ k ih =>
      simpa [BaseDuplicatingSystem.counter, freeLiveCoord] using ih

@[simp] theorem freeRecordCoord_counter (k : Nat) :
    freeRecordCoord (freeBaseSystem.counter k) = 0 := by
  induction k with
  | zero => rfl
  | succ k ih =>
      simpa [BaseDuplicatingSystem.counter, freeRecordCoord] using ih

@[simp] theorem freeLiveCoord_wrapChain (i : Nat) (t : freeBaseSystem.T) :
    freeLiveCoord (freeBaseSystem.wrapChain freeSeedY i t) = freeLiveCoord t := by
  induction i generalizing t with
  | zero =>
      simp [BaseDuplicatingSystem.wrapChain]
  | succ i ih =>
      simpa [BaseDuplicatingSystem.wrapChain, freeBaseSystem, freeSchema, freeLiveCoord, freeSeedY]
        using ih t

@[simp] theorem freeRecordCoord_wrapChain (i : Nat) (t : freeBaseSystem.T) :
    freeRecordCoord (freeBaseSystem.wrapChain freeSeedY i t)
      = i + freeRecordCoord t := by
  induction i generalizing t with
  | zero =>
      simp [BaseDuplicatingSystem.wrapChain]
  | succ i ih =>
      simpa [BaseDuplicatingSystem.wrapChain, freeBaseSystem, freeSchema, freeRecordCoord,
        freeSeedY, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using
        congrArg Nat.succ (ih t)

@[simp] theorem freeLiveCoord_recur_counter (n : Nat) :
    freeLiveCoord (freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter n)) = 1 := by
  change freeLiveCoord freeSeedX + freeLiveCoord freeSeedY
      + freeLiveCoord (freeBaseSystem.counter n) + 1 = 1
  rw [freeLiveCoord_counter]
  simp [freeLiveCoord, freeSeedX, freeSeedY]

@[simp] theorem freeRecordCoord_recur_counter (n : Nat) :
    freeRecordCoord (freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter n)) = 0 := by
  change freeRecordCoord freeSeedX + freeRecordCoord freeSeedY
      + freeRecordCoord (freeBaseSystem.counter n) = 0
  rw [freeRecordCoord_counter]
  simp [freeRecordCoord, freeSeedX, freeSeedY]

@[simp] theorem freeLiveCoord_canonicalTrace (k i : Nat) (_hik : i ≤ k) :
    freeLiveCoord
      (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i) = 1 := by
  change
    freeLiveCoord
      (freeBaseSystem.wrapChain freeSeedY i
        (freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter (k - i)))) = 1
  rw [freeLiveCoord_wrapChain]
  simp

@[simp] theorem freeRecordCoord_canonicalTrace (k i : Nat) (_hik : i ≤ k) :
    freeRecordCoord
      (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i) = i := by
  change
    freeRecordCoord
      (freeBaseSystem.wrapChain freeSeedY i
        (freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter (k - i)))) = i
  rw [freeRecordCoord_wrapChain]
  simp

@[simp] theorem freeLiveCoord_terminal (k : Nat) :
    freeLiveCoord (freeBaseSystem.wrapChain freeSeedY k freeSeedX) = 0 := by
  simp [freeSeedX]

@[simp] theorem freeRecordCoord_terminal (k : Nat) :
    freeRecordCoord (freeBaseSystem.wrapChain freeSeedY k freeSeedX) = k := by
  simp [freeSeedX]

/-- Concrete record-emission witness for the free step-duplicating syntax. -/
def freeRecordEmissionWitness :
    BaseDuplicatingSystem.RecordEmissionWitness freeBaseSystem freeSeedX freeSeedY where
  liveCoord := freeLiveCoord
  recordCoord := freeRecordCoord
  live_at_canonical := by
    intro k i hik
    simpa using freeLiveCoord_canonicalTrace k i hik
  record_at_canonical := by
    intro k i hik
    simpa using freeRecordCoord_canonicalTrace k i hik
  live_at_terminal := by
    intro k
    simpa using freeLiveCoord_terminal k
  record_at_terminal := by
    intro k
    simpa using freeRecordCoord_terminal k

/-- Semantic free-syntax emitter: the live observable distinguishes live
computation from terminal record, and the record observable decodes the wrapper
depth directly. -/
def freeFaithfulRecordEmitter :
    BaseDuplicatingSystem.FaithfulRecordEmitter freeBaseSystem freeSeedX freeSeedY where
  LiveObs := Bool
  liveObsDecEq := inferInstance
  RecordObs := Nat
  liveObs := fun t => decide (freeLiveCoord t = 1)
  recordObs := freeRecordCoord
  liveToken := true
  terminalToken := false
  decodeRecord := id
  live_at_canonical := by
    intro k i hik
    simp [freeLiveCoord_canonicalTrace k i hik]
  live_at_terminal := by
    intro k
    simp [freeLiveCoord_terminal k]
  live_token_ne_terminal := by
    decide
  decode_record_at_canonical := by
    intro k i hik
    simpa using freeRecordCoord_canonicalTrace k i hik
  decode_record_at_terminal := by
    intro k
    simpa using freeRecordCoord_terminal k

/-- The free primitive syntax realizes the computation-to-record crossing at
every nontrivial depth budget. -/
theorem freeRecordEmission_realizes_crossing {K : Nat} (hK : 1 ≤ K) :
    freeRecordEmissionWitness.RealizesComputationToRecordCrossing K := by
  exact freeRecordEmissionWitness.realizesComputationToRecordCrossing_of_one_le hK

/-- The free primitive syntax exposes a hidden progress coordinate that is not
meta-accessible at stage 0 but becomes exactly accessible through the emitted
record family. -/
theorem freeRecordEmission_requires_hidden_progress {K : Nat} (hK : 1 ≤ K) :
    ∃ φ : Fin (K + 1) → Nat,
      ¬ OperatorKO7.InformationAccess.AccessibleFrom
          (freeRecordEmissionWitness.liveRecordAccessModel K).metaView φ
        ∧ OperatorKO7.InformationAccess.AccessibleFrom
            (fun x =>
              ((freeRecordEmissionWitness.liveRecordAccessModel K).metaView x, φ x))
            (freeRecordEmissionWitness.liveRecordAccessModel K).verdict := by
  exact freeRecordEmissionWitness.liveRecordAccess_requires_hidden_state hK

/-- The same crossing can be recovered from the more semantic
`FaithfulRecordEmitter` interface, not only from the raw numeric witness. -/
theorem freeFaithfulRecordEmitter_realizes_crossing {K : Nat} (hK : 1 ≤ K) :
    (freeFaithfulRecordEmitter.toRecordEmissionWitness).RealizesComputationToRecordCrossing K := by
  exact freeFaithfulRecordEmitter.realizesComputationToRecordCrossing_of_one_le hK

/-- The semantic free emitter also exposes the hidden progress coordinate
through the emitted record family. -/
theorem freeFaithfulRecordEmitter_requires_hidden_progress {K : Nat} (hK : 1 ≤ K) :
    ∃ φ : Fin (K + 1) → Nat,
      ¬ OperatorKO7.InformationAccess.AccessibleFrom
          ((freeFaithfulRecordEmitter.toRecordEmissionWitness).liveRecordAccessModel K).metaView φ
        ∧ OperatorKO7.InformationAccess.AccessibleFrom
            (fun x =>
              (((freeFaithfulRecordEmitter.toRecordEmissionWitness).liveRecordAccessModel K).metaView x,
                φ x))
            ((freeFaithfulRecordEmitter.toRecordEmissionWitness).liveRecordAccessModel K).verdict := by
  exact freeFaithfulRecordEmitter.requires_hidden_state hK

/-- Projection that erases wrapper payloads and retains the generator-side
recursor spine on the free syntax. -/
@[simp] def freeGeneratorProjection : freeBaseSystem.T → freeBaseSystem.T
  | .base => .base
  | .succ t => .succ (freeGeneratorProjection t)
  | .wrap _ y => freeGeneratorProjection y
  | .recur b s n => .recur (freeGeneratorProjection b) (freeGeneratorProjection s)
      (freeGeneratorProjection n)

@[simp] theorem freeGeneratorProjection_counter (k : Nat) :
    freeGeneratorProjection (freeBaseSystem.counter k) = freeBaseSystem.counter k := by
  induction k with
  | zero => rfl
  | succ k ih =>
      change FreeTerm.succ (freeGeneratorProjection (freeBaseSystem.counter k))
        = FreeTerm.succ (freeBaseSystem.counter k)
      rw [ih]

@[simp] theorem freeCounterDepth_counter (k : Nat) :
    freeCounterDepth (freeBaseSystem.counter k) = k := by
  induction k with
  | zero => rfl
  | succ k ih =>
      change freeCounterDepth (FreeTerm.succ (freeBaseSystem.counter k)) = k + 1
      simpa [freeCounterDepth] using congrArg Nat.succ ih

@[simp] theorem freeGeneratorProjection_wrapChain (i : Nat) (t : freeBaseSystem.T) :
    freeGeneratorProjection (freeBaseSystem.wrapChain freeSeedY i t) = freeGeneratorProjection t := by
  induction i generalizing t with
  | zero =>
      simp [BaseDuplicatingSystem.wrapChain]
  | succ i ih =>
      simpa [BaseDuplicatingSystem.wrapChain] using ih t

@[simp] theorem freeGeneratorProjection_recur_counter (n : Nat) :
    freeGeneratorProjection
      (freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter n))
      = freeBaseSystem.recur freeSeedX freeSeedY (freeBaseSystem.counter n) := by
  change FreeTerm.recur (freeGeneratorProjection freeSeedX)
      (freeGeneratorProjection freeSeedY)
      (freeGeneratorProjection (freeBaseSystem.counter n))
    = FreeTerm.recur FreeTerm.base (FreeTerm.succ FreeTerm.base) (freeBaseSystem.counter n)
  simp [freeSeedX, freeSeedY, freeGeneratorProjection_counter]

@[simp] theorem freeProjectedRank_canonicalTrace (k i : Nat) (_hik : i ≤ k) :
    freeProjectionRank.rank
        (freeGeneratorProjection
          (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i))
      = BaseDuplicatingSystem.trace_ctr k i := by
  rw [BaseDuplicatingSystem.canonicalTrace, freeGeneratorProjection_wrapChain,
    BaseDuplicatingSystem.trace_ctr]
  rw [freeGeneratorProjection_recur_counter]
  change freeCounterDepth
      (FreeTerm.recur FreeTerm.base (FreeTerm.succ FreeTerm.base)
        (freeBaseSystem.counter (k - i))) = k - i
  simp [freeCounterDepth, freeCounterDepth_counter]

@[simp] theorem freeProjectedRank_terminal (k : Nat) :
    freeProjectionRank.rank
        (freeGeneratorProjection (freeBaseSystem.wrapChain freeSeedY k freeSeedX)) = 0 := by
  simp [freeSeedX, freeProjectionRank]

/-- The free primitive duplicator carries the semantic ambient projection
kernel used to derive the conservation-law interface without any stage-indexed
extension data. -/
def freeSemanticProjectionKernel :
    BaseDuplicatingSystem.SemanticProjectionKernel freeBaseSystem where
  project := freeGeneratorProjection
  projectedRank := by
    simpa [freeBaseSystem, freeSchema] using freeProjectionRank
  project_base := by
    rfl
  project_succ := by
    intro t
    rfl
  project_wrap := by
    intro x y
    rfl
  project_recur := by
    intro b s n
    rfl

/-- The weaker rank-level kernel is also realized on the free primitive
duplicator. -/
def freeRankLevelProjectionKernel :
    BaseDuplicatingSystem.RankLevelProjectionKernel freeBaseSystem :=
  BaseDuplicatingSystem.RankLevelProjectionKernel.ofSemanticProjectionKernel
    freeSemanticProjectionKernel

/-- Free-syntax projective emitter: the same primitive duplicator carries both
the record-emission crossing and a licensed projection back to the generator
counter. -/
def freeProjectiveRecordEmitter :
    BaseDuplicatingSystem.ProjectiveRecordEmitter freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := freeFaithfulRecordEmitter
  project := freeGeneratorProjection
  projectedRank := by
    simpa [freeBaseSystem, freeSchema] using freeProjectionRank
  project_canonical := by
    intro k i hik
    simpa [freeBaseSystem, freeSchema] using freeProjectedRank_canonicalTrace k i hik
  project_terminal := by
    intro k
    simpa [freeBaseSystem, freeSchema] using freeProjectedRank_terminal k

/-- The same free-syntax bridge packaged at the more semantic
generator-preserving level. -/
def freeGeneratorPreservingRecordEmitter :
    BaseDuplicatingSystem.GeneratorPreservingRecordEmitter freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := freeFaithfulRecordEmitter
  project := freeGeneratorProjection
  generatorCoord := freeCounterDepth
  generator_base := by rfl
  generator_succ := by intro t; rfl
  generator_wrap := by intro x y; rfl
  generator_recur := by intro b s n; rfl
  project_canonical := by
    intro k i hik
    simpa [freeProjectionRank] using freeProjectedRank_canonicalTrace k i hik
  project_terminal := by
    intro k
    simpa [freeProjectionRank] using freeProjectedRank_terminal k

/-- The free primitive duplicator also satisfies the stronger semantically
coherent generator-preserving interface. -/
def freeSemanticGeneratorPreservingRecordEmitter :
    BaseDuplicatingSystem.SemanticGeneratorPreservingRecordEmitter
      freeBaseSystem freeSeedX freeSeedY where
  toGeneratorPreservingRecordEmitter := freeGeneratorPreservingRecordEmitter
  project_base := by
    rfl
  project_succ := by
    intro t
    rfl
  project_wrap := by
    intro x y
    rfl
  project_recur := by
    intro b s n
    rfl

/-- The weaker projected-generator interface is also realized concretely on the
free primitive duplicator. -/
def freeProjectedGeneratorWitness :
    BaseDuplicatingSystem.ProjectedGeneratorWitness freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := freeFaithfulRecordEmitter
  project := freeGeneratorProjection
  projectedRankFn := freeCounterDepth
  projected_base := by
    rfl
  projected_succ := by
    intro t
    rfl
  projected_wrap := by
    intro x y
    rfl
  projected_recur := by
    intro b s n
    rfl
  project_canonical := by
    intro k i hik
    simpa [freeProjectionRank] using freeProjectedRank_canonicalTrace k i hik
  project_terminal := by
    intro k
    simpa [freeProjectionRank] using freeProjectedRank_terminal k

/-- The conservation-law precursor is also realized concretely on the free
primitive duplicator. -/
def freeConservationBasedGeneratorEmitter :
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter
      freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := freeFaithfulRecordEmitter
  project := freeGeneratorProjection
  projectedRankFn := freeCounterDepth
  projected_base := by
    rfl
  projected_succ := by
    intro t
    rfl
  projected_wrap := by
    intro x y
    rfl
  projected_recur := by
    intro b s n
    rfl
  conservation_at_canonical := by
    intro k i hik
    rw [show freeCounterDepth
        (freeGeneratorProjection (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i))
          = BaseDuplicatingSystem.trace_ctr k i by
          simpa [freeProjectionRank] using freeProjectedRank_canonicalTrace k i hik]
    rw [freeFaithfulRecordEmitter.decode_record_at_canonical k i hik]
    simp [BaseDuplicatingSystem.trace_ctr]
    omega
  conservation_at_terminal := by
    intro k
    rw [show freeCounterDepth
        (freeGeneratorProjection (freeBaseSystem.wrapChain freeSeedY k freeSeedX)) = 0 by
          simpa [freeProjectionRank] using freeProjectedRank_terminal k]
    rw [freeFaithfulRecordEmitter.decode_record_at_terminal k]
    omega

/-- The weaker semantic-conservation interface is also realized concretely on
the free primitive duplicator. -/
def freeSemanticConservationBasedGeneratorEmitter :
    BaseDuplicatingSystem.SemanticConservationBasedGeneratorEmitter
      freeBaseSystem freeSeedX freeSeedY where
  toConservationBasedGeneratorEmitter := freeConservationBasedGeneratorEmitter
  project_base := by
    rfl
  project_succ := by
    intro t
    rfl
  project_wrap := by
    intro x y
    rfl
  project_recur := by
    intro b s n
    rfl

/-- The genuinely step-indexed conservation interface is also realized on the
free primitive duplicator. -/
def freeStageIndexedConservationEmitter :
    BaseDuplicatingSystem.StageIndexedConservationEmitter
      freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := freeFaithfulRecordEmitter
  projectedStageCoord := fun k i => BaseDuplicatingSystem.trace_ctr k i
  projectedTerminalCoord := fun _ => 0
  conservation_at_canonical := by
    intro k i hik
    rw [freeFaithfulRecordEmitter.decode_record_at_canonical k i hik]
    unfold BaseDuplicatingSystem.trace_ctr
    omega
  conservation_at_terminal := by
    intro k
    rw [freeFaithfulRecordEmitter.decode_record_at_terminal k]
    omega

/-- Structural fold on the free primitive syntax. -/
def freeConstructorFold {α : Type}
    (z : α) (hs : α → α) (hw : α → α → α) (hr : α → α → α → α) :
    FreeTerm → α
  | .base => z
  | .succ t => hs (freeConstructorFold z hs hw hr t)
  | .wrap x y => hw (freeConstructorFold z hs hw hr x) (freeConstructorFold z hs hw hr y)
  | .recur b s n =>
      hr (freeConstructorFold z hs hw hr b)
        (freeConstructorFold z hs hw hr s)
        (freeConstructorFold z hs hw hr n)

/-- The free primitive syntax carries the expected constructor-recursion
principle by structural recursion on `FreeTerm`. -/
def freeConstructorRecursor :
    BaseDuplicatingSystem.ConstructorRecursor freeBaseSystem where
  fold := @freeConstructorFold
  fold_base := by
    intro α z hs hw hr
    rfl
  fold_succ := by
    intro α z hs hw hr t
    rfl
  fold_wrap := by
    intro α z hs hw hr x y
    rfl
  fold_recur := by
    intro α z hs hw hr b s n
    rfl

@[simp] theorem freeConstructorRecursor_project_seedX_zero :
    (freeConstructorRecursor.toSemanticProjectionKernel.projectedRank).rank
      ((freeConstructorRecursor.toSemanticProjectionKernel.project) freeSeedX) = 0 := by
  rfl

/-- The canonical free-syntax extension principle lifting the stage-indexed
interface to the global conservation-law interface. -/
def freeStageIndexedConservationExtension :
    (BaseDuplicatingSystem.StageIndexedConservationEmitter.Extension
      freeStageIndexedConservationEmitter) where
  project := freeGeneratorProjection
  projectedRankFn := freeCounterDepth
  projected_base := by
    rfl
  projected_succ := by
    intro t
    rfl
  projected_wrap := by
    intro x y
    rfl
  projected_recur := by
    intro b s n
    rfl
  extends_canonical := by
    intro k i hik
    rw [show freeCounterDepth
      (freeGeneratorProjection (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i))
        = BaseDuplicatingSystem.trace_ctr k i by
          simpa [freeProjectionRank] using freeProjectedRank_canonicalTrace k i hik]
    exact
      BaseDuplicatingSystem.StageIndexedConservationEmitter.projectedStage_eq_trace_ctr
        freeStageIndexedConservationEmitter k i hik
  extends_terminal := by
    intro k
    rw [show freeCounterDepth
      (freeGeneratorProjection (freeBaseSystem.wrapChain freeSeedY k freeSeedX)) = 0 by
        simpa [freeProjectionRank] using freeProjectedRank_terminal k]
    exact
      BaseDuplicatingSystem.StageIndexedConservationEmitter.projectedTerminal_zero
        freeStageIndexedConservationEmitter k

/-- The weaker semantic raw stage-indexed extension is also realized on the
free primitive duplicator. -/
def freeStageIndexedSemanticExtension :
    (BaseDuplicatingSystem.StageIndexedConservationEmitter.SemanticExtension
      freeStageIndexedConservationEmitter) where
  toExtension := freeStageIndexedConservationExtension
  project_base := by
    rfl
  project_succ := by
    intro t
    rfl
  project_wrap := by
    intro x y
    rfl
  project_recur := by
    intro b s n
    rfl

namespace BaseDuplicatingSystem.FaithfulRecordEmitter

/-- On the free primitive duplicator, the ambient conservation-law interface is
available directly from any faithful record emitter. No separate extension
principle is needed because the free carrier already has the canonical ambient
projection `freeGeneratorProjection` and ambient counter-depth rank
`freeCounterDepth`. -/
def toFreeAmbientConservationBasedGeneratorEmitter
    (E : BaseDuplicatingSystem.FaithfulRecordEmitter freeBaseSystem freeSeedX freeSeedY) :
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter
      freeBaseSystem freeSeedX freeSeedY where
  toFaithfulRecordEmitter := E
  project := freeGeneratorProjection
  projectedRankFn := freeCounterDepth
  projected_base := by
    rfl
  projected_succ := by
    intro t
    rfl
  projected_wrap := by
    intro x y
    rfl
  projected_recur := by
    intro b s n
    rfl
  conservation_at_canonical := by
    intro k i hik
    rw [show freeCounterDepth
        (freeGeneratorProjection (freeBaseSystem.canonicalTrace freeSeedX freeSeedY k i))
          = BaseDuplicatingSystem.trace_ctr k i by
          simpa [freeProjectionRank] using freeProjectedRank_canonicalTrace k i hik]
    rw [E.decode_record_at_canonical k i hik]
    simp [BaseDuplicatingSystem.trace_ctr]
    omega
  conservation_at_terminal := by
    intro k
    rw [show freeCounterDepth
        (freeGeneratorProjection (freeBaseSystem.wrapChain freeSeedY k freeSeedX)) = 0 by
          simpa [freeProjectionRank] using freeProjectedRank_terminal k]
    rw [E.decode_record_at_terminal k]
    omega

/-- Therefore any faithful record emitter on the free primitive duplicator
already induces the full computation-to-confession bridge through the ambient
free carrier itself. -/
theorem realizesComputationToConfessionBridge_onFree_of_one_le
    (E : BaseDuplicatingSystem.FaithfulRecordEmitter freeBaseSystem freeSeedX freeSeedY)
    {K : Nat} (hK : 1 ≤ K) :
    BaseDuplicatingSystem.ProjectiveRecordEmitter.RealizesComputationToConfessionBridge
      ((toFreeAmbientConservationBasedGeneratorEmitter E).toProjectedGeneratorWitness.toProjectiveRecordEmitter) K := by
  exact
    BaseDuplicatingSystem.ConservationBasedGeneratorEmitter.realizesComputationToConfessionBridge_of_one_le
      (toFreeAmbientConservationBasedGeneratorEmitter E) hK

end BaseDuplicatingSystem.FaithfulRecordEmitter

